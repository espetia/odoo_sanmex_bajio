<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_draft_requisitions_reminder" model="ir.cron">
            <field name="name">Purchase Requisition: Draft Reminder</field>
            <field name="model_id" ref="model_purchase_requisition_custom"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_draft_requisitions_reminder()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 14:00:00')"/>
            <field name="active" eval="True"/>
            <field name="doall" eval="False"/>
        </record>
    </data>
</odoo>