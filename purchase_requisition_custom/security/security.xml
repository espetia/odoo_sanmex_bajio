<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Category for the module -->
    <record model="ir.module.category" id="module_category_purchase_requisition">
        <field name="name">Purchase Requisitions</field>
        <field name="description">Helps you manage purchase requisitions.</field>
        <field name="sequence">10</field>
    </record>

    <!-- Basic User Group -->
    <record id="group_purchase_requisition_user" model="res.groups">
        <field name="name">Basic Requisition User</field>
        <field name="category_id" ref="module_category_purchase_requisition"/>
    </record>

    <!-- Warehouse Agent Group -->
    <record id="group_purchase_requisition_warehouse" model="res.groups">
        <field name="name">Warehouse Agent</field>
        <field name="category_id" ref="module_category_purchase_requisition"/>
        <field name="implied_ids" eval="[(4, ref('group_purchase_requisition_user'))]"/>
    </record>

    <!-- Manager Group -->
    <record id="group_purchase_requisition_manager" model="res.groups">
        <field name="name">Purchase Manager</field>
        <field name="category_id" ref="module_category_purchase_requisition"/>
        <field name="implied_ids" eval="[(4, ref('group_purchase_requisition_warehouse')), (4, ref('purchase.group_purchase_manager'))]"/>
    </record>

    <!-- Record Rules -->
    <!-- Basic User: Only own requisitions -->
    <record id="rule_purchase_requisition_own" model="ir.rule">
        <field name="name">Purchase Requisition: Own Only</field>
        <field name="model_id" ref="model_purchase_requisition_custom"/>
        <field name="domain_force">[('requester_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_purchase_requisition_user'))]"/>
    </record>

    <!-- Manager: All requisitions -->
    <record id="rule_purchase_requisition_all" model="ir.rule">
        <field name="name">Purchase Requisition: All</field>
        <field name="model_id" ref="model_purchase_requisition_custom"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_purchase_requisition_manager'))]"/>
    </record>
</odoo>