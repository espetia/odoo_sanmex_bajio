<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="view_purchase_requisition_custom_form" model="ir.ui.view">
            <field name="name">purchase.requisition.custom.form</field>
            <field name="model">purchase.requisition.custom</field>
            <field name="arch" type="xml">
                <form string="Purchase Requisition">
                    <header>
                        <button name="%(action_create_po_wizard)d" string="Create PO" type="action" class="btn-primary" 
                                states="quote,waiting,authorized,done" groups="purchase.group_purchase_manager"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,quote,waiting,authorized,done,cancel" options="{'clickable': '1'}"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_purchase_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart"
                                    attrs="{'invisible': [('purchase_order_count', '=', 0)]}" groups="purchase_requisition_custom.group_purchase_requisition_user">
                                <field name="purchase_order_count" widget="statinfo" string="Purchase Orders"/>
                            </button>
                        </div>
                        <div class="oe_title">
                            <span class="o_form_label">Reference</span>
                            <h1>
                                <field name="name"/>
                            </h1>
                            <span class="o_form_label">Name</span>
                            <h2>
                                <field name="requisition_name" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            </h2>
                        </div>
                        <group>
                            <group>
                                <field name="requester_id" readonly="1" force_save="1" options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="manager_id" attrs="{'readonly': [('state', '!=', 'draft')]}" options="{'no_create': True, 'no_create_edit': True}"/>
                                <field name="rubro_id" attrs="{'readonly': [('state', '!=', 'draft')]}" options="{'no_create': True, 'no_create_edit': True}"/>
                            </group>
                            <group>
                                <field name="expiration_date" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                                <field name="requires_vehicle" invisible="1"/>
                                <field name="vehicle_id" attrs="{'invisible': [('requires_vehicle', '=', False)], 'readonly': [('state', '!=', 'draft')]}" options="{'no_create': True, 'no_create_edit': True}"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Lines">
                                <field name="line_ids" attrs="{'readonly': [('state', '!=', 'draft')]}">
                                    <tree editable="bottom">
                                        <field name="product_id" options="{'no_create': True, 'no_create_edit': True}" domain="[('purchase_ok', '=', True)]"/>
                                        <field name="name"/>
                                        <field name="product_qty"/>
                                        <field name="product_uom_id" options="{'no_create': True, 'no_create_edit': True}"/>
                                        <field name="po_line_id" readonly="1" groups="purchase_requisition_custom.group_purchase_requisition_user"/>
                                        <field name="image" widget="image" optional="hide"/>
                                    </tree>
                                </field>
                            </page>
                            <page string="Purchase Orders" groups="purchase_requisition_custom.group_purchase_requisition_user">
                                <field name="purchase_order_ids" readonly="1">
                                    <tree no_open="1" string="Purchase Orders">
                                        <field name="date_approve"/>
                                        <field name="partner_id"/>
                                        <field name="date_order"/>
                                        <field name="date_planned"/>
                                        <field name="amount_total" widget="monetary"/>
                                        <field name="state"/>
                                        <field name="currency_id" invisible="1"/>
                                        <button name="get_formview_action" type="object" string="Open" icon="fa-external-link" class="oe_highlight"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                        <field name="comments" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- Tree View -->
        <record id="view_purchase_requisition_custom_tree" model="ir.ui.view">
            <field name="name">purchase.requisition.custom.tree</field>
            <field name="model">purchase.requisition.custom</field>
            <field name="arch" type="xml">
                <tree string="Purchase Requisitions" decoration-danger="expiration_date &lt; current_date and state in ('draft', 'quote')">
                    <field name="name"/>
                    <field name="requester_id"/>
                    <field name="manager_id"/>
                    <field name="rubro_id"/>
                    <field name="expiration_date"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_purchase_requisition_custom_search" model="ir.ui.view">
            <field name="name">purchase.requisition.custom.search</field>
            <field name="model">purchase.requisition.custom</field>
            <field name="arch" type="xml">
                <search string="Search Requisitions">
                    <field name="name"/>
                    <field name="requester_id"/>
                    <field name="manager_id"/>
                    <field name="rubro_id"/>
                </search>
            </field>
        </record>

        <!-- Kanban View -->
        <record id="view_purchase_requisition_custom_kanban" model="ir.ui.view">
            <field name="name">purchase.requisition.custom.kanban</field>
            <field name="model">purchase.requisition.custom</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" class="o_kanban_small_column" records_draggable="1" group_create="false">
                    <field name="state"/>
                    <field name="name"/>
                    <field name="requisition_name"/>
                    <field name="requester_id"/>
                    <field name="manager_id"/>
                    <field name="rubro_id"/>
                    <field name="expiration_date"/>
                    <field name="vehicle_id"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/> - <field name="requisition_name"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div>
                                        Requester: <field name="requester_id"/>
                                    </div>
                                    <div>
                                        Manager: <field name="manager_id"/>
                                    </div>
                                    <div>
                                        Rubro: <field name="rubro_id"/>
                                    </div>
                                    <div t-if="record.vehicle_id.raw_value">
                                        Vehicle: <field name="vehicle_id"/>
                                    </div>
                                    <div t-if="record.expiration_date.raw_value and record.expiration_date.raw_value &lt; (new Date())" class="text-danger">
                                        Expired: <field name="expiration_date"/>
                                    </div>
                                    <div t-else="">
                                        Expires: <field name="expiration_date"/>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Action -->
        <record id="action_purchase_requisition_custom" model="ir.actions.act_window">
            <field name="name">Purchase Requisitions</field>
            <field name="res_model">purchase.requisition.custom</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Create a new purchase requisition
              </p>
            </field>
        </record>

        <!-- Make Purchase Root Menu visible to Requisition Users -->
        <record id="purchase.menu_purchase_root" model="ir.ui.menu">
            <field name="groups_id" eval="[(4, ref('purchase_requisition_custom.group_purchase_requisition_user'))]"/>
        </record>

        <record id="purchase.menu_procurement_management" model="ir.ui.menu">
            <field name="groups_id" eval="[(4, ref('purchase.group_purchase_user'))]"/>
        </record>

        <!-- Menu -->
        <menuitem id="menu_purchase_requisition_custom"
                  name="Purchase Requisitions"
                  parent="purchase.menu_purchase_root"
                  action="action_purchase_requisition_custom"
                  sequence="15"/>
    </data>
</odoo>
