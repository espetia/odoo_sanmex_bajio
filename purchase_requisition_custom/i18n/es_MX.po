#. module: purchase_requisition_custom
#: model:mail.template,body_html:purchase_requisition_custom.email_template_draft_requisitions_reminder
msgid ""
"<div style=\"background-color: #F3F4F6; padding: 40px; font-family: Arial, sans-serif; text-align: center;\">\n"
"                    <div style=\"max-width: 600px; margin: 0 auto; background-color: #FFFFFF; padding: 30px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1); text-align: left;\">\n"
"                        <h2 style=\"color: #333333; font-size: 20px; margin-top: 0; display: flex; align-items: center;\">\n"
"                            <span style=\"color: #E53935; font-size: 24px; margin-right: 8px;\">🔴</span> ¡Requisiciones Pendientes de Validación!\n"
"                        </h2>\n"
"                        <p style=\"color: #555555; font-size: 15px; line-height: 1.5; margin-top: 15px;\">\n"
"                            Hola <strong><t t-out=\"object.name or ''\"/></strong>,<br/><br/>\n"
"                            Le informamos que actualmente tiene <strong><t t-out=\"len(ctx.get('draft_requisitions', []))\"/></strong> requisiciones de compra en estado de borrador esperando por su revisión en el sistema.\n"
"                        </p>\n"
"                        \n"
"                        <div style=\"background-color: #F9FAFB; padding: 15px; border-radius: 6px; margin: 20px 0; border: 1px solid #E5E7EB;\">\n"
"                            <ul style=\"margin: 0; padding-left: 20px; color: #444444; font-size: 14px;\">\n"
"                                <t t-foreach=\"ctx.get('draft_requisitions')\" t-as=\"req\">\n"
"                                    <li style=\"margin-bottom: 5px;\">\n"
"                                        <strong><t t-out=\"req.name\"/></strong> - Solicitante: <t t-out=\"req.requester_id.name\"/>\n"
"                                    </li>\n"
"                                </t>\n"
"                            </ul>\n"
"                        </div>\n"
"\n"
"                        <div style=\"margin: 30px 0;\">\n"
"                            <a href=\"/web\" style=\"background-color: #6366F1; color: #FFFFFF; padding: 12px 24px; text-decoration: none; border-radius: 6px; font-weight: bold; font-size: 15px; display: inline-block;\">\n"
"                                Ver Requisiciones\n"
"                            </a>\n"
"                        </div>\n"
"                        \n"
"                        <p style=\"color: #777777; font-size: 13px; margin-bottom: 0; border-top: 1px solid #E5E7EB; padding-top: 15px;\">\n"
"                            Saludos,<br/>\n"
"                            <strong><t t-out=\"object.company_id.name or ''\"/></strong>\n"
"                        </p>\n"
"                    </div>\n"
"                </div>\n"
"            "
msgstr ""

