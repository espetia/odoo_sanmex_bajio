<?xml version='1.0' encoding='utf-8'?>
<odoo>
  
    <record model="ir.ui.view" id="sale_view_order_fields_custom">
      <field name="name">sale_view_order_fields_custom</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.view_order_form"/>
      <field name="arch" type="xml">


      <xpath expr="//field[@name='sale_order_template_id']" position="replace">
          <field name="rv_nombre_obra" string="RV Nombre Obra:" attrs="{'invisible': [('no_cliente', '!=', 'NV1')]}"/>
          <field name="vrd_entrega" string="VRD Entrega:"/>
          <field name="nombre_obra_o_proyecto" string="Nombre Obra o Proyecto" attrs="{'invisible': [('no_cliente', '=', 'NV1')]}"/>                 
          <field name="cobrar_en_entrega" string="Cobrar en Entrega"/>        
          <field name="link_de_ubicacin"/>
          <field name="n_cliente_contratista"/>
          <field name="pn_nombre_de_obraproyecto"/>
          <field name="pr_cliente_contratista"/>
          <field name="vista_de_direccin"/>

      </xpath>

      <xpath expr="//field[@name='partner_id']" position="before">  
        <field name="no_cliente" string="No. Cliente"/>
         <field name="nombre_prospecto" string="Nombre Prospecto"/>         
      </xpath>
      <xpath expr="//field[@name='payment_term_id']" position="after">
        <field name="fecha_entrega_log" />
      </xpath>
    <!--<xpath expr="//field[@name='partner_invoice_id']" position="attributes">
        <attribute name="attrs">{"readonly": [["state","not in",["draft","sent","sale"]]]}</attribute>
        <attribute name="invisible">1</attribute>
     </xpath>
     <xpath expr="//field[@name='partner_shipping_id']" position="attributes">
      <attribute name="domain">[["parent_id", "=", partner_id]]</attribute>
      <attribute name="options">{"always_reload": True,"no_create":true}</attribute>
    </xpath>
    <xpath expr="//field[@name='payment_term_id']" position="attributes">
    <attribute name="attrs">{"required": [["payment_term_id","=",False]]}</attribute>
  </xpath>
  <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='order_lines']/field[@name='order_line']/tree[1]/field[@name='discount']" position="attributes">
    <attribute name="optional">hide</attribute>
    </xpath>-->

  <xpath expr="//form[1]/sheet[1]/notebook[1]" position="inside">
    <page name="clientesinfo" string="Informacion Cliente">
      <group>
        <group>         
          <field name="contacto_de_solicitud" />
          <field name="telefono_solicitud" />
          <field name="puesto" string="Puesto" attrs="{'required': [('puesto', '=', False)]}"/>
          <field name="correo_solicitud" />          
          <field name="contacto_que_recibe" string="Contacto que Recibe" />
          <field name="tel_de_quien_recibe" string="Tel. de quien recibe" />  
          <field name="referencia_entrega" />        
        </group>
        <group>
          <field name="numero_de_sucursal" string="Numero de Sucursal"/>   
          <field name="nombre_de_sucursal" string="Nombre de Sucursal"/>  
          <field name="gerente_de_sucursal" string="Gerente de Sucursal"/>    
          <field name="operador" string="Operador"/>          
        </group>
      </group>
    </page>
    <!-- <page name="pruebas" string="Inf. Prueba">
      <group>
        <group string="Operación">         
         
          <field name="firma_del_cliente" string="FIRMA DEL CLIENTE"/>          
          <field name="excelente" string="EXCELENTE"/>   
          <field name="cantidad" string="CANTIDAD"/>
          <field name="color" string="Color:"/>
          <field name="color_1"/>

        </group>
      
      </group>
    </page> -->
  </xpath>

      </field>
    </record>

 <record model="ir.ui.view" id="sale_rental_view_order_fields_custom">
      <field name="name">sale_view_order_fields_custom</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale_renting.rental_order_primary_form_view"/>
      <field name="arch" type="xml">          
                
                   
            

             <xpath expr="//form[1]/sheet[1]/notebook[1]" position="inside">
                <page string="Información de Retiro" name="retiro">
                  <group>
                    <group>                      
                     <field name="fecha_retiro" />
			    <field name="cantidad_1" string="Cantidad / Modelo / Color"/>
			    
			    <field name="modelo" string="Modelo" attrs="{}" invisible="1"/>
			    <field name="rea_de_entrega"/>
			    <field name="ref_entrega"/>
			    <field name="related_field_fwB8p"/>


                    </group>
                    <group>
                      <field name="operador_unidad" string="Operador"/>
                    </group>
                  </group>
                </page>
                <page string="Reubicación" name="reubicación">
                  
                    <group>
                      <field name="direccin_actual" string="Dirección actual"/>
                      <field name="description_rb" />
                      <field name="cantidad_rb" />
                    </group>                   
                </page>
        </xpath>

      </field>
    </record>

 <record model="ir.ui.view" id="sale_view_order_fields_custom_2">
      <field name="name">sale_view_order_fields_custom</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding"/>
      <field name="arch" type="xml">
        <xpath expr="//tree[1]/field[@name='name']" position="after">           
            <field name="invoice_ids" widget="many2many_tags" domain="[]" optional="hide"/>            
            <field name="nombre_obra_o_proyecto" optional="hide"/>
            <field name="calle_entrega" string="Calle Entrega." optional="hide"/>
            <field name="fecha_entrega_log" string="Fecha de Entrega" optional="show"/>
       </xpath>
        <xpath expr="//field[@name='create_date']" position="attributes">
          <attribute name="optional">hide</attribute>
        </xpath>
        <xpath expr="//field[@name='expected_date']" position="after">
          <field name="no_cliente"/>
        </xpath>
        <xpath expr="//field[@name='partner_id']" position="after">
          <field name="partner_shipping_id" optional="show"/>
          <field name="nombre_prospecto"/>
        </xpath>
	<!--<xpath expr="//field[@name='website_id']" position="attributes">

          <attribute name="attrs">{}</attribute>
          <attribute name="invisible">1</attribute>
	</xpath>-->
        <xpath expr="//field[@name='company_id']" position="attributes">
          <attribute name="attrs">{}</attribute>
          <attribute name="invisible">1</attribute>
        </xpath>

      </field>
    </record>

     <record model="ir.ui.view" id="sale_view_order_fields_customo_1">
      <field name="name">sale_view_order_fields_custom</field>
      <field name="model">sale.order</field>
      <field name="inherit_id" ref="sale.view_order_tree"/>
      <field name="arch" type="xml">

        <xpath expr="//tree[1]/field[@name='name']" position="after">
          <field name="invoice_ids" widget="many2many_tags"/>
          <field name="nombre_obra_o_proyecto" optional="hide"/>
          <field name="no_cliente" optional="hide"/>
          <field name="fecha_entrega_log" string="Fecha de Entrega" optional="show"/>
        </xpath>
        
        

      <xpath expr="//field[@name='date_order']" position="after">
        <field name="numero_de_sucursal" optional="hide"/>        
        <field name="gerente_de_sucursal" optional="hide"/>
        <field name="nombre_de_sucursal" optional="hide"/>       
      </xpath>

  <xpath expr="//field[@name='commitment_date']" position="attributes">
    <attribute name="attrs">{"readonly": [["state","not in",["draft","sent"]]]}</attribute>
    <attribute name="invisible">1</attribute>
  </xpath>

  <xpath expr="//field[@name='expected_date']" position="attributes">
    <attribute name="attrs">{}</attribute>
    <attribute name="invisible">1</attribute>
  </xpath>

  

  <xpath expr="//field[@name='partner_id']" position="attributes">
    <attribute name="optional">hide</attribute>
  </xpath>

  <xpath expr="//field[@name='company_id']" position="attributes">
    <attribute name="attrs">{}</attribute>
    <attribute name="invisible">1</attribute>
  </xpath>

      </field>
    </record>

     <record model="ir.ui.view" id="account_invoice_form_fields_custom">
            <field name="name">account.invoice.fields.custom</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
              <field name="payment_reference" position="after">
              <field name="fecha_de_cancelacin" string="Fecha de Cancelación" help="Agregar fecha cuando se cancela la factura en el sat"/>
            </field>
            </field>
          </record>

  <record id="inherit_view_sale_order_campos_sanmex_tree" model="ir.ui.view">
    <field name="name">sale.order.view.tree.renting.campos_sanmex</field>
    <field name="model">sale.order</field>
    <field name="inherit_id" ref="sale_renting.rental_order_view_tree"/>
    <field name="arch" type="xml">
      <xpath expr="//tree[1]/field[@name='name']" position="after">
          <field name="fecha_entrega_log" optional="hide"/>
          <field name="invoice_ids" widget="many2many_tags" optional="hide"/>
      </xpath>
    </field>
  </record>

  <record id="inherit_tree_id_campos_sanmex_account_move_out" model="ir.ui.view">
    <field name="name">account.move.out.view.tree.inherit.campos.sanmex</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_out_invoice_tree"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='name']" position="after">
        <field name="partner_shipping_id" string="Nombre de Obra" optional="hide"/>
        <field name="create_uid" string="Creado por" optional="hide"/>
        <field name="fecha_de_pago" optional="hide"/>
        <field name="__last_update" optional="hide"/>
        <field name="write_date" optional="hide"/>
        <field name="fecha_de_cancelacin" optional="hide"/>
        <field name="folio_fiscal" optional="hide"/>
      </xpath>
    </field>
  </record>

  <record id="view_partner_form_inherit_campos_sanmex" model="ir.ui.view">
    <field name="name">res.partner.view.form.inherit.campos.sanmex</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='website']" position="attributes">
        <attribute name="invisible">1</attribute>
      </xpath>
    </field>
  </record>
  
  </odoo>
