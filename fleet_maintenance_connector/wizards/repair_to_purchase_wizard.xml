<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View repair.to.purchase.wizard form -->
    <record id="view_repair_to_purchase_wizard_form" model="ir.ui.view">
        <field name="name">view.repair.to.purchase.wizard.form</field>
        <field name="model">repair.to.purchase.wizard</field>
        <field name="arch" type="xml">
            <form string="Repair To Purchase Wizard">
                <sheet>
                    <group>
                        <group>
                            <field name="repair_order_id" readonly="1"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="group_by_supplier"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Productos a Comprar">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="selected"/>
                                    <field name="product_id"/>
                                    <field name="product_qty"/>
                                    <field name="product_uom"/>
                                    <field name="price_unit"/>
                                    <field name="supplier_id" 
                                           domain="[('is_company', '=', True), ('supplier_rank', '>', 0)]"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_create_purchase_order" 
                            type="object" 
                            string="Crear Orden(es) de Compra" 
                            class="oe_highlight"/>
                    <button string="Cancelar" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
