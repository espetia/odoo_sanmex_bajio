<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- View repair.order form -->
    <record id="inherit_fleet_maintenance_connector_view_repair_order_form" model="ir.ui.view">
        <field name="name">inherit.fleet.maintenance.connector.view.repair.order.form</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_validate']" position="after">
                <button name="action_create_purchase_order" type="object" class="oe_highlight"
                        string="Crear Orden(es) de Compra"/>
                <button name="action_create_order_from_kit" type="object" class="oe_highlight" string="Crear PO KIT"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_purchase_orders"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file-text-o"
                        attrs="{'invisible': [('purchase_count', '=', 0)]}">
                    <field name="purchase_count" widget="statinfo" string="OC"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='product_id']" position="after">
                <field name="equipment_id" attrs="{'readonly': 1}"/>
            </xpath>
            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="purchase_states_summary"/>
            </xpath>
        </field>
    </record>

</odoo>