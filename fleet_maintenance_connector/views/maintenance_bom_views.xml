<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View maintenance.bom View Tree -->
    <record id="view_maintenance_bom_tree" model="ir.ui.view">
        <field name="name">view.maintenance.bom.tree</field>
        <field name="model">maintenance.bom</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <!-- View maintenance.bom form -->
    <record id="view_maintenance_bom_form" model="ir.ui.view">
        <field name="name">view.maintenance.bom.form</field>
        <field name="model">maintenance.bom</field>
        <field name="arch" type="xml">
            <form string="Kits Mantenimiento">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Name..."/>
                        </h1>
                    </div>
                    <notebook>
                        <page name="bom_lines" string="Componentes">
                            <field name="bom_line_ids" context="{'default_bom_id': active_id}">
                                <tree editable="bottom" create="true" delete="true">
                                    <field name="product_id" options="{'no_create': True}"/>
                                    <field name="product_tmpl_id" />
                                    <field name="quantity"/>
                                    <field name="product_uom_id" options="{'no_create': True}"/>
                                </tree>
                            </field>
                        </page>
                        <page name="config_purchase" string="Ajustes Compras">
                            <group>
                                <field name="partner_id" options="{'no_create': True}"/>
                                <field name="account_analytic_id" options="{'no_create': True}" domain="[('purchase_account', '=', True)]" />
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View maintenance.bom search -->
    <record id="view_maintenance_bom_search" model="ir.ui.view">
        <field name="name">view.maintenance.bom.search</field>
        <field name="model">maintenance.bom</field>
        <field name="arch" type="xml">
            <search>
                <group expand="1" string="Group By">
                    <filter string="Name" name="name" domain="[]" context="{'group_by':'name'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action maintenance.bom -->
    <record id="action_maintenance_bom" model="ir.actions.act_window">
        <field name="name">Kits de mantenimiento</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">maintenance.bom</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click para crear un nuevo kit de mantenimiento.
            </p>
        </field>
    </record>

    <!-- Menu maintenance.bom -->
     <menuitem
        id="maiintenance_bom_menu"
        name="Kist de Mantenimiento"
        action="action_maintenance_bom"
        parent="maintenance.menu_maintenance_configuration"
        sequence="10"/>

</odoo>
