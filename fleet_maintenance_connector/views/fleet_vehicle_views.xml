<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- View fleet.vehicle form -->
    <record id="inherit_fleet_maintenance_view_fleet_vehicle_form" model="ir.ui.view">
        <field name="name">inherit.fleet.maintenance.view.fleet.vehicle.form</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_accept_driver_change']" position="after">
                <button string="Crear mantenimiento" name="action_create_request_maintenance" type="object" class="oe_highlight"/>
            </xpath>
            <xpath expr="//button[@name='return_action_to_open']" position="after">
                <button name="action_view_maintenance_requests" type="object" class="oe_stat_button" icon="fa-hospital-o">
                    <field name="maintenance_request_count" string="" widget="statinfo"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='company_id']" position="after">
                <field name="id_maintenance_bom" />
                <field name="maintenance_state" />
            </xpath>
            <xpath expr="//div[@name='button_box']" position="after">
                <!--<widget name="web_ribbon" bg_color="bg-warning" title="Solicitud Mant"  attrs="{'invisible': [('maintenance_state','!=','maintenance_requested')]}"/>
                <widget name="web_ribbon" bg_color="bg-danger" title="En Mant"  attrs="{'invisible': [('maintenance_state','!=','in_maintenance')]}"/>-->
                <widget name="web_ribbon" bg_color="bg-success" title="Disponible"  attrs="{'invisible': [('maintenance_state','!=','available')]}"/>
            </xpath>
        </field>
    </record>

    <record id="fleet_vehicle_inherit_tree_maintenance_connector" model="ir.ui.view">
        <field name="name">fleet.vehicle.view.inherit.tree.maintenance.connector</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='manager_id']" position="after">
                <field name="current_maintenance_request_id" optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>