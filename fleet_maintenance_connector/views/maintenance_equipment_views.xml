<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- View maintenance.equipment form -->
    <record id="inherit_fleet_maintenance_view__maintenance_equipment_form" model="ir.ui.view">
        <field name="name">inherit.fleet.maintenance.view.maintenance.equipment.form</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="vehicle_id" />
            </xpath>
        </field>
    </record>


    <!-- View maintenance.equipment tree -->
    <record id="inherit_fleet_maintenance_view_maintenance_equipment_tree" model="ir.ui.view">
        <field name="name">inherit.fleet.maintenance.view.maintenance.equipment.tree</field>
        <field name="model">maintenance.equipment</field>
        <field name="inherit_id" ref="maintenance.hr_equipment_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="vehicle_id" />
                <field name="id_maintenance_bom"/>
            </xpath>
        </field>
    </record>

</odoo>