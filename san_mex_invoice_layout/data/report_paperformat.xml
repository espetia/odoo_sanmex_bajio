<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Custom Paperformat for SANMEX Invoices -->
        <record id="paperformat_sanmex_invoice" model="report.paperformat">
            <field name="name">Factura SANMEX (A4)</field>
            <field name="default" eval="True"/>
            <field name="format">A4</field>
            <field name="page_height">0</field>
            <field name="page_width">0</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">70</field>
            <field name="margin_bottom">40</field>
            <field name="margin_left">15</field>
            <field name="margin_right">15</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">60</field>
            <field name="dpi">90</field>
        </record>

        <!-- Override standard invoice report actions to use this new paperformat -->
        <record id="account.account_invoices" model="ir.actions.report">
            <field name="paperformat_id" ref="san_mex_invoice_layout.paperformat_sanmex_invoice"/>
        </record>
        
        <record id="account.account_invoices_without_payment" model="ir.actions.report">
            <field name="paperformat_id" ref="san_mex_invoice_layout.paperformat_sanmex_invoice"/>
        </record>
    </data>
</odoo>
