<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="custom_dashboard.OwlSalesDashboard" owl="1">
        <div class="vh-100 overflow-auto bg-muted">
            <div class="row m-3">
                <div class="col-lg-7">
                    <div class="row">
                        <div class="col m-0 p-0">
                            <div class="shadow-sm border m-2 p-4 bg-white">
                                <div class="d-flex align-items-center justify-content-between">
                                    <h1 class="text-primary fw-bold">
                                        Ventas Dashboard
                                    </h1>
                                    <div>
                                        <select t-model="state.period" class="form-select" t-on-change="onChangePeriod">
                                            <option value="0">Seleccionar Periodo</option>
                                            <option value="7">Últimos 7 días</option>
                                            <option value="30">Últimos 30 días</option>
                                            <option value="90">Últimos 90 días</option>
                                            <option value="365">Últimos 365 días</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                       <KpiCard t-on-click.synthetic="viewQuotations" name="'Cotizaciones'" value="state.quotations.value" percentage="state.quotations.percentage"/>
                       <KpiCard t-on-click.synthetic="viewOrders" name="'Ordenes'" value="state.orders.value" percentage="state.orders.percentage"/>
                       <KpiCard t-on-click.synthetic="viewRevenues" name="'Ingresos'" value="state.orders.revenue" percentage="state.orders.revenue_percentage" />
                       <KpiCard t-on-click.synthetic="viewRevenues" name="'Ordenes promedio'" value="state.orders.average" percentage="state.orders.average_percentage"/>
                    </div>
                    <div class="row">
                        <div class="col-lg-6 m-0 p-0">
                            <div class="shadow-sm border m-2 p-4 bg-white">
                                <div class="d-flex align-items-center justify-content-between">
                                    <h1 class="text-primary fw-bold">
                                        Top Productos
                                    </h1>
                                    <div class="px-3 py-1 bg-primary cursor-pointer">
                                        <span class="fa fa-arrow-right text-white"/>
                                    </div>
                                </div>
                                <ChartRenderer type="'doughnut'" title="'Top Products Report'" t-props="state.topProducts"/>
                            </div>
                        </div>
                        <div class="col-lg-6 m-0 p-0">
                            <div class="shadow-sm border m-2 p-4 bg-white">
                                <div class="d-flex align-items-center justify-content-between">
                                    <h1 class="text-primary fw-bold">
                                        Top Ventas Personas
                                    </h1>
                                    <div class="px-3 py-1 bg-primary cursor-pointer">
                                        <span class="fa fa-arrow-right text-white"/>
                                    </div>
                                </div>
                                <ChartRenderer type="'pie'" title="'Top Sales People Report'" t-props="state.topSalesPeople"/>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5">
                    <div class="row">
                        <div class="col m-0 p-0">
                            <div class="shadow-sm border m-2 p-4 bg-white">
                                <div class="d-flex align-items-center justify-content-between">
                                    <h1 class="text-primary fw-bold">
                                        Ventas mensuales
                                    </h1>
                                    <div class="px-3 py-1 bg-primary cursor-pointer">
                                        <span class="fa fa-arrow-right text-white"/>
                                    </div>
                                </div>
                                <ChartRenderer type="'bar'" title="'Montly Sales Report'" t-props="state.monthlySales"/>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col m-0 p-0">
                            <div class="shadow-sm border m-2 p-4 bg-white">
                                <div class="d-flex align-items-center justify-content-between">
                                    <h1 class="text-primary fw-bold">
                                        Pedidos de cliente
                                    </h1>
                                    <div class="px-3 py-1 bg-primary cursor-pointer">
                                        <span class="fa fa-arrow-right text-white"/>
                                    </div>
                                </div>
                                <ChartRenderer type="'bar'" title="'Partner Orders Report'" t-props="state.partnerOrders"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>