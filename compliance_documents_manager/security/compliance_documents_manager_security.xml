<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Security category definition -->
    <record id="category_compliance_documents_manager" model="ir.module.category">
        <field name="name">Administracion de documentos</field>
        <field name="description">Security category for Compliance Documents Manager</field>
        <field name="sequence">1</field>
    </record>

    <!-- Group for regular users -->
    <record id="group_compliance_documents_manager_user" model="res.groups">
        <field name="name">Usuario</field>
        <field name="category_id" ref="category_compliance_documents_manager"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Group for administrators -->
    <record id="group_compliance_documents_manager_manager" model="res.groups">
        <field name="name">Administrador</field>
        <field name="category_id" ref="category_compliance_documents_manager"/>
        <field name="implied_ids" eval="[(4, ref('group_compliance_documents_manager_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="compliance_document_line_visibility_rule_user" model="ir.rule">
        <field name="name">Visibilidad de documentos de administracion</field>
        <field name="model_id" ref="model_compliance_document_line"/>
        <field name="perm_create" eval="False"/>
        <field name="groups" eval="[(4, ref('group_compliance_documents_manager_user'))]"/>
        <field name="domain_force">[('is_visible', '=', True)]
        </field>
    </record>

    <record id="compliance_document_line_visibility_rule_manager" model="ir.rule">
        <field name="name">A description of the rule's role</field>
        <field name="model_id" ref="model_compliance_document_line"/>
        <field name="groups" eval="[(4, ref('group_compliance_documents_manager_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]
        </field>
    </record>

</odoo>