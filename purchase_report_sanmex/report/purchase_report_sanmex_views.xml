<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record model="ir.ui.view" id="view_purchase_order_pivot_sanmex">
            <field name="name">product.month.pivot</field>
            <field name="model">purchase.report.sanmex</field>
            <field name="arch" type="xml">
                <pivot string="Compras San Mex" display_quantity="1" sample="1">
                    <field name="category_id" type="row"/>
                    <field name="order_id" type="measure"/>
                    <field name="untaxed_total" type="measure"/>
                    <field name="price_total" type="measure"/>
                    <!--<field name="amount_due" type="measure"/> -->
                </pivot>
            </field>
        </record>
        <record model="ir.ui.view" id="view_purchase_order_graph_sanmex">
            <field name="name">product.month.graph</field>
            <field name="model">purchase.report.sanmex</field>
            <field name="arch" type="xml">
                <graph string="Compras San Mex" type="line" sample="1">
                    <field name="date_approve" interval="day"/>
                    <field name="untaxed_total" type="measure"/>
                </graph>
            </field>
        </record>

        <record id="purchase_report_view_tree_sanmex" model="ir.ui.view">
            <field name="name">purchase.report.view.tree.sanmex</field>
            <field name="model">purchase.report.sanmex</field>
            <field name="arch" type="xml">
                <tree string="Compras San Mex">
                    <field name="date_order" widget="date"/>
                    <field name="order_id" optional="show"/>
                    <field name="partner_id" optional="show"/>
                    <field name="product_id" optional="show"/>
                    <field name="category_id" optional="show"/>
                    <field name="cost_center" optional="show"/>
                    <field name="payment_state" optional="show"/>
                    <field name="invoice_status" optional="show"/>
                    <field name="user_id" optional="show" widget="many2one_avatar_user"/>
                    <field name="company_id" optional="show" groups="base.group_multi_company"/>
                    <field name="qty_ordered" optional="hide" sum="Sum of Qty Ordered"/>
                    <field name="qty_received" optional="hide" sum="Sum of Qty Received"/>
                    <field name="qty_billed" optional="hide" sum="Sum of Qty Billed"/>
                    <field name="currency_id" optional="show" invisible="1"/>
                    <field name="untaxed_total" optional="hide" widget="monetary" sum="Sum of Untaxed Total"/>
                    <field name="price_total" optional="show" widget="monetary" sum="Sum of Total"/>
                    <field name="state" optional="show"/>
                </tree>
            </field>
        </record>

        <record id="view_purchase_order_search_sanmex" model="ir.ui.view">
        <field name="name">report.purchase.order.search</field>
        <field name="model">purchase.report.sanmex</field>
        <field name="arch" type="xml">
            <search string="Purchase Orders">
                <filter string="Cotizaciones" name="quotes" domain="[('state','in',('draft','sent'))]"/>
                <filter string="Ordenes de compra" name="orders" domain="[('state','!=','draft'), ('state','!=','sent'), ('state','!=','cancel')]"/>
                <filter string="Confirmation Date Last Year" name="later_than_a_year_ago" domain="[('date_approve', '&gt;=', ((context_today()-relativedelta(years=1)).strftime('%Y-%m-%d')))]"/>
                <filter name="filter_date_order" date="date_order"/>
                <filter name="filter_date_approve" date="date_approve" default_period="this_month"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <group expand="0" string="Extended Filters">
                    <field name="user_id"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="date_order"/>
                    <field name="date_approve"/>
                    <field name="category_id" filter_domain="[('category_id', 'child_of', self)]"/>
                </group>
                <group expand="1" string="Group By">
                    <filter string="Proveedor" name="group_partner_id" context="{'group_by':'partner_id'}"/>
                    <filter string="País de origen" name="country_id" context="{'group_by':'country_id'}"/>
                    <filter string="Personal responsable" name="user_id" context="{'group_by':'user_id'}"/>
                    <filter string="Producto" name="group_product_id" context="{'group_by':'product_id'}"/>
                    <filter string="Quincena" name="fortnight_pay" context="{'group_by':'fortnight_pay'}"/>
                    <filter string="Cuenta analítica" name="account_analytic_id" context="{'group_by':'account_analytic_id'}"/>
                    <filter string="Categoría de producto" name="group_category_id" context="{'group_by':'category_id'}"/>
                    <filter string="Estatus" name="status" context="{'group_by':'state'}"/>
                    <filter string="Compañia" name="company" context="{'group_by':'company_id'}" groups="base.group_multi_company"/>
                    <separator/>
                    <filter string="Fecha de orden" name="order_month" context="{'group_by': 'date_order:month'}"/>
                    <filter string="Fecha de confirmación" name="group_date_approve_month" context="{'group_by': 'date_approve:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_purchase_order_report_all_sanmex" model="ir.actions.act_window">
        <field name="name">Compras Sanmex</field>
        <field name="res_model">purchase.report.sanmex</field>
        <field name="view_mode">graph,pivot</field>
        <field name="view_id"></field>  <!-- force empty -->
        <field name="help">Purchase Analysis allows you to easily check and analyse your company purchase history and performance. From this menu you can track your negotiation performance, the delivery performance of your vendors, etc.</field>
        <field name="target">current</field>
    </record>

    <menuitem id="purchase_report_sanmex" name="Compras sanmex" parent="purchase.purchase_report_main" sequence="99" groups="purchase.group_purchase_manager" action="action_purchase_order_report_all_sanmex"/>

</odoo>