<?xml version="1.0" encoding="utf-8"?>
<templates>
    <t t-name="base_logistics_sanmex.PlanningLogisticsDashboard">
        <div class="o_rent_logistics_dashboard container">
          <div class="row" style="margin: 10px;">
            <div class="col-sm-4">
              <table class="table table-sm">
                <thead>
                  <tr>
                    <td class="o_text">
                      <i class="fa fa-truck fa-lg"></i>
                      <div>Operaciones</div>
                    </td>
                    <td class="o_main o_dashboard_action" title="Obra" context='{"search_default_to_confirm": true}'>
                      <a href="#" class="href"><t t-esc="values['total_confirm']"/> <br/> Confirmado</a>
                      
                    </td>
                    <td class="o_main o_dashboard_action" title="Obra" context='{"search_default_in_progress": true}'>
                      <a href="#" class="href"><t t-esc="values['total_in_progress']"/> <br/> Próxima entrega</a>
                    </td>
                    <td class="o_main o_dashboard_action" title="Obra" context='{"search_default_delivery": true}'>
                      <a href="#" class="href"><t t-esc="values['total_delivery']"/> <br/> <div class="text-smx-label">Rentados</div></a>
                    </td>
                  </tr>
                </thead>
              </table>
            </div>
  
            <div class="col-sm-3">
              <table class="table table-sm">
                  <thead>
                    <tr>
                      <td class="o_text">
                        <div>Ordenes por</div>
                      </td>
                      <td class="o_main o_dashboard_action_rent" title="Obra" context='{"search_default_to_delivery_smx": true}'>
                        <a href="#" class="href"><t t-esc="values['sanitary_qty_dis']"/> <br/> Planificar</a>
                        
                      </td>
                    </tr>
                  </thead>
              </table>
            </div>
            <div class="col-sm-5">
                <table class="table table-sm">
                  <thead>
                    <tr>
                      <td class="o_text">
                        <div>Inventario de baños hoy</div>
                      </td>
                      <td class="o_main o_dashboard_action" title="Disponibles">
                        <a href="#" class="href"><t t-esc="values['sanitary_qty_dis']"/> <br/> Disponibles</a>
                        
                      </td>
                      <td class="o_main o_dashboard_action" title="En limpieza">
                        <a href="#" class="href"><t t-esc="values['sanitary_qty_clean']"/> <br/> En limpieza</a>
                      </td>
                      <td class="o_main o_dashboard_action" title="Mantenimiento">
                        <a href="#" class="href"><t t-esc="values['sanitary_qty_mantt']"/> <br/> <div class="text-smx-label">Mantenimiento</div></a>
                      </td>
                    </tr>
                  </thead>
                </table>
            </div>
            
            
          </div>
        </div>
    </t>
    

</templates>
