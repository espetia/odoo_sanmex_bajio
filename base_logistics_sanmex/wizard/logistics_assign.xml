<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View logistics_assign form -->
    <record id="view_logistics_assign_form" model="ir.ui.view">
        <field name="name">view.logistics_assign.form</field>
        <field name="model">logistics.assign</field>
        <field name="arch" type="xml">
            <form string="Logistics_assign">
                <div class="oe_title">
                    <h1>
                        <field name="sale_id" readonly="1"/>
                    </h1>
                </div>
                <group>
                    <group>
                        <field name="partner_id" readonly="1"/>
                        <field name="route_id" />
                        <field name="stock_house_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="date_delivery" />
                        <field name="user_id" />
                    </group>
                </group>
                <group>
                    <field name="logistics_assign_line_ids">
                        <tree create="false" editable="top">
                            <field name="product_id" readonly="1" force_save="1" options="{'no_open': True}"/>
                            <field name="order_line_id" invisible="1"/>
                            <field name="logistics_assign_id" invisible="1"/>
                            <field name="qty_reserved" readonly="1"/>
                        </tree>
                    </field>
                </group>
                <footer>
                    <button name="add" type="object" string="Generar ruta" class="oe_highlight"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action logistics_assign -->
    <!--<record id="action_logistics_assign" model="ir.actions.act_window">
        <field name="name">Logistics_assign</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">logistics_assign</field>
        <field name="view_mode">form</field>
        <field name="binding_model_id" ref="addon.model_model_name"/>
        <field name="target">new</field>
    </record>-->

</odoo>
