<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View logistic.route.line View Tree -->
    <record id="view_logistic_planning_tree" model="ir.ui.view">
        <field name="name">view.logistic.planning.tree</field>
        <field name="model">logistics.planning</field>
        <field name="arch" type="xml">
            <tree js_class="planning_logistics_list_dashboard">
                <field name="name" optional="hide"/>
                <field name="sale_id" />
                <field name="stock_house_id"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="route_id"/>
                <field name="qty_demand"/>
                <field name="qty_confirm"/>
                <field name="date_rent"/>
                <field name="date_delivery" optional="hide"/>
                <field name="date_return" optional="hide"/>
                <field name="state"/>
                <button name="action_assign_serial" string="Salida" title="Assign Serial Numbers" type="object" icon="fa-plus-square"/>
                <button name="action_print_report_planning" string="Imprimir" title="Imprimir report" type="object" icon="fa-plus-square"/>
            </tree>
        </field>
    </record>

    <!-- View logistic.route.line form -->
    <record id="view_logistic_planning_form" model="ir.ui.view">
        <field name="name">view.logistic.planning.form</field>
        <field name="model">logistics.planning</field>
        <field name="arch" type="xml">
            <form string="Monitor de rutas">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirm,in_progress,delivery"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Nombre..."/>
                        </h1>
                    </div>
                    <group name="sale_header">
                        <group name="partner_details">
                            <field name="partner_id" widget="res_partner_many2one" context="{'res_partner_search_mode': 'customer', 'show_address': 1, 'show_vat': True}" options="{&quot;always_reload&quot;: True}"/>
                            <field name="sale_id" />
                            <field name="stock_house_id"/>
                            <field name="user_id"/>
                            <field name="product_tmplt_id"/>
                            <field name="route_id"/>
                            <field name="qty_demand"/>
                            <field name="qty_confirm"/>
                        </group>
                        <group name="sale_details">
                            <field name="date_order" />
                            <field name="date_rent"/>
                            <field name="date_delivery"/>
                            <field name="date_return"/>
                        </group>
                        
                    </group>
                    <group>
                        
                    </group>
                    
                </sheet>
            </form>
        </field>
    </record>

    
    <record id="view_logistics_planning_calendar" model="ir.ui.view">
                <field name="name">view.logistics_planning.search</field>
                <field name="model">logistics.planning</field>
                <field name="arch" type="xml">
                   <calendar string="" date_start="date_delivery" color="route_id">
                    <field name="partner_id" filters="1"/>
                    <field name="route_id"  filters="1"/>
                    <field name="product_tmplt_id"/>
                    <field name="qty_demand"/>
                    <field name="qty_confirm"/>
                   </calendar>
                </field>
    </record>
    

    <!-- View logistic.route.line search -->
    <record id="view_logistic_planning_search" model="ir.ui.view">
        <field name="name">view.logistic.route.line.search</field>
        <field name="model">logistics.planning</field>
        <field name="arch" type="xml">
            <search>
                <group expand="1" string="Group By">
                    <filter string="Nombre" name="name" domain="[]" context="{'group_by':'name'}"/>
                    <filter name="to_confirm" string="Confirmados" domain="[('state', '=', 'confirm')]"/>
                    <filter name="in_progress" string="Proxima entrega" domain="[('state', '=', 'in_progress')]"/>
                    <filter name="delivery" string="Rentados" domain="[('state', '=', 'delivery')]"/>
                    <filter name="filter_today" string="Para hoy" domain="[('date_delivery','&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0))),
                       ('date_delivery','&lt;=', datetime.datetime.combine(context_today(), datetime.time(23,59,59)))]"/>
                       <filter name="filter_tomorrow" string="Para mañana" domain="[('date_delivery','&gt;=', datetime.datetime.combine((context_today()+datetime.timedelta(days=1)), datetime.time(0,0,0))),
                       ('date_delivery','&lt;=', datetime.datetime.combine((context_today()+datetime.timedelta(days=1)), datetime.time(23,59,59)))]"/>
                    <!--<filter string="Cliente" name="partner_id" domain="[]" context="{'group_by':'partner_id'}"/>-->
                    <filter string="Por ruta" name="filter_route" domain="[]" context="{'group_by':'route_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action logistic.route.line -->
    <record id="action_logistic_planning" model="ir.actions.act_window">
        <field name="name">Monitor de Rutas</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">logistics.planning</field>
        <field name="view_mode">tree,form,calendar</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                There is no examples click here to add new Logistic Route Line.
            </p>
        </field>
    </record>

    <record id="planning_logistics_action_dashboard_list" model="ir.actions.act_window">
        <field name="name">Monitor de rutas</field>
        <field name="res_model">logistics.planning</field>
        <field name="view_mode">tree,form,calendar</field>
        <field name="view_id" ref="base_logistics_sanmex.view_logistic_planning_tree"/>
        <field name="search_view_id" ref="base_logistics_sanmex.view_logistic_planning_search"/>
        <field name="target">main</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_empty_folder">
                Rutas
            </p>
        </field>
    </record>

    <menuitem id="menu_planning" name="Monitor de Rutas" parent="logistics_sanmex_menu" action="action_logistic_planning" sequence="5"/>
</odoo>
