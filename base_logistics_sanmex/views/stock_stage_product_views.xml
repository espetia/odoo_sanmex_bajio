<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View stock_stage_product View Tree -->
    <record id="view_stock_stage_product_tree" model="ir.ui.view">
        <field name="name">view.stock_stage_product.tree</field>
        <field name="model">stock.stage.product</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle" optional="show"/>
                <field name="name"/>
                <field name="fold" />
            </tree>
        </field>
    </record>

    <!-- View stock_stage_product form -->
    <record id="view_stock_stage_product_form" model="ir.ui.view">
        <field name="name">view.stock_stage_product.form</field>
        <field name="model">stock.stage.product</field>
        <field name="arch" type="xml">
            <form string="Stock_stage_product">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Name..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="sequence" />
                        <field name="fold" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View stock_stage_product search -->
    <record id="view_stock_stage_product_search" model="ir.ui.view">
        <field name="name">view.stock_stage_product.search</field>
        <field name="model">stock.stage.product</field>
        <field name="arch" type="xml">
            <search>
                <group expand="1" string="Group By">
                    <filter string="Name" name="name" domain="[]" context="{'group_by':'name'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action stock_stage_product -->
    <record id="action_stock_stage_product" model="ir.actions.act_window">
        <field name="name">Stock_stage_product</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">stock.stage.product</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                There is no examples click here to add new Stock_stage_product.
            </p>
        </field>
    </record>

    <menuitem
        id="stock_stage_product_menu"
        name="Etapas de Bodega"
        action="action_stock_stage_product"
        parent="menu_logistic_sanmex_settings"
        sequence="10"/>

</odoo>
