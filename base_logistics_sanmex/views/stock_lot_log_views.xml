<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View stock_lot_log View Tree -->
    <record id="view_stock_lot_log_tree" model="ir.ui.view">
        <field name="name">view.stock_lot_log.tree</field>
        <field name="model">stock.lot.log</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="lot_id" />
                <field name="product_id"/>
                <field name="stage_id_new" />
                <field name="stage_id_old" />
                <field name="date_change" />
            </tree>
        </field>
    </record>

    <!-- View stock_lot_log form -->
    <record id="view_stock_lot_log_form" model="ir.ui.view">
        <field name="name">view.stock_lot_log.form</field>
        <field name="model">stock.lot.log</field>
        <field name="arch" type="xml">
            <form string="Stock_lot_log">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Name..."/>
                        </h1>
                        <group>
                            <group>
                                <field name="lot_id" />
                                <field name="product_id"/>
                                <field name="stage_id_new" />
                                <field name="stage_id_old" />
                                <field name="date_change" />
                            </group>
                        </group>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View stock_lot_log search -->
    <record id="view_stock_lot_log_search" model="ir.ui.view">
        <field name="name">view.stock_lot_log.search</field>
        <field name="model">stock.lot.log</field>
        <field name="arch" type="xml">
            <search>
                <group expand="1" string="Group By">
                    <filter string="Lote" name="lot_id" domain="[]" context="{'group_by':'lot_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action stock_lot_log -->
    <record id="action_stock_lot_log" model="ir.actions.act_window">
        <field name="name">Stock_lot_log</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">stock.lot.log</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                There is no examples click here to add new Stock_lot_log.
            </p>
        </field>
    </record>

    <menuitem id="menu_logistic_sanmex_report_log_stock" name="Logs Bodega" action="action_stock_lot_log" parent="menu_logistic_sanmex_report" sequence="99"/>

</odoo>
