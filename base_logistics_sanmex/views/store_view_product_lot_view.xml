<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <record id="stock_production_lot_view_kanban_logistics_sanmex" model="ir.ui.view">
            <field name="name">stock.production.lot.view.kanban.logistics.sanmex</field>
            <field name="model">stock.production.lot</field>
            <field name="mode">primary</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_small_column o_kanban_project_tasks" default_group_by="stage_product_id" banner_route="/logistics/get_panel_data_production_lot_sanmex">
                    <field name="stage_product_id" />
                    <field name="color" />
                    <progressbar field="kanban_state" colors='{"done": "success", "blocked": "danger", "normal": "muted"}'/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="#{kanban_color(record.color.raw_value)} oe_kanban_global_click o_has_icon oe_kanban_content oe_kanban_card">
                                <div class="oe_kanban_content oe_kanban_global_click">
                                    <div class="o_kanban_record_top">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                                <field name="name"/>
                                            </strong>
                                        </div>
                                    </div>
                                    <div class="o_kanban_record_body">
                                        <field name="product_id" />
                                        <div>
                                            
                                        </div>
                                    </div>
                                    <div class="o_kanban_record_bottom" t-if="!selection_mode">
                                        <div class="oe_kanban_bottom_left">
                                            <span></span>
                                        </div>
                                        <div class="oe_kanban_bottom_right" t-if="!selection_mode">
                                            <field name="kanban_state" widget="state_selection" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="view_production_lot_form_inherit_logistics_sanmex" model="ir.ui.view">
            <field name="name">view.production.view.form.inherit.logistics.sanmex</field>
            <field name="model">stock.production.lot</field>
            <field name="inherit_id" ref="stock.view_production_lot_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='description']" position="before">
                    <page name="config_sanmex" string="Configuración Sanmex">
                        <group>
                            <field name="is_lot_sanmex"/>
                            <field name="type_product"/>
                            <field name="model_product" />
                            <field name="color_product"/>
                            <field name="color"/>
                            <field name="state_inventory_product"/>
                            <field name="stage_product_id"/>
                            <field name="stock_house_id"/>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>

        <record id="logistics_sanmex_stock_production_lot_search_view" model="ir.ui.view">
            <field name="name">stock.production.lot.search.inheri.logistics.sanmex</field>
            <field name="model">stock.production.lot</field>
            <field name="inherit_id" ref="stock.search_product_lot_filter"/>
            <field name="arch" type="xml">
              <xpath expr="//filter[@name='group_by_product']" position="after">
                <filter string="Lote Sanmex" name="filter_to_sanmex" domain="[('is_lot_sanmex', '=', True)]"/>
              </xpath>
              <xpath expr="//group[1]" position="after">
                <searchpanel>
                    <field name="model_product" enable_counters="1" icon="fa-car"/>
                    <field name="type_product" enable_counters="1" icon="fa-database"/>
                    <field name="color_product" enable_counters="1" icon="fa-paint-brush"/>
                </searchpanel>
              </xpath>
            </field>
          </record>

        <record id="stock.action_production_lot_form" model="ir.actions.act_window">
            <field name="view_mode">tree,kanban,form</field>
        </record>
    
        <record id="stock_lot_action_dashboard_kanban" model="ir.actions.act_window">
            <field name="name">Estado de Bodega</field>
            <field name="res_model">logistics.planning</field>
            <field name="view_mode">tree,form,calendar</field>
            <field name="view_id" ref="base_logistics_sanmex.stock_production_lot_view_kanban_logistics_sanmex"/>
            <field name="search_view_id" ref="base_logistics_sanmex.logistics_sanmex_stock_production_lot_search_view"/>
            <field name="target">main</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_empty_folder">
                    Bodega
                </p>
            </field>
        </record>

</odoo>
