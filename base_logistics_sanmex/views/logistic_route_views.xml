<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- View logistic.route View Tree -->
    <record id="view_logistics_route_tree" model="ir.ui.view">
        <field name="name">view.logistics.route.tree</field>
        <field name="model">logistics.route</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="stock_house_id"/>
            </tree>
        </field>
    </record>

    <!-- View logistic.route form -->
    <record id="view_logistics_route_form" model="ir.ui.view">
        <field name="name">view.logistics.route.form</field>
        <field name="model">logistics.route</field>
        <field name="arch" type="xml">
            <form string="Rutas">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Name..."/>
                        </h1>
                        <group>
                            <field name="stock_house_id" />
                        </group>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- View logistic.route search -->
    <record id="view_logistics_route_search" model="ir.ui.view">
        <field name="name">view.logistics.route.search</field>
        <field name="model">logistics.route</field>
        <field name="arch" type="xml">
            <search>
                <group expand="1" string="Group By">
                    <filter string="Name" name="name" domain="[]" context="{'group_by':'name'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action logistic.route -->
    <record id="action_logistics_route" model="ir.actions.act_window">
        <field name="name">Rutas</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">logistics.route</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                There is no examples click here to add new Logistic Route.
            </p>
        </field>
    </record>

</odoo>
