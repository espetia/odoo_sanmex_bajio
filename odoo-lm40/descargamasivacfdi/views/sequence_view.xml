<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sequences for peticiones -->
        <record id="seq_sheet_solicituddescarga" model="ir.sequence">
            <field name="name">solictud cfdi</field>
            <field name="code">peticionescfdi</field>
            <field name="prefix">SO-</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>
        <!-- Sequences for descargas -->
        <record id="seq_sheet_descarga" model="ir.sequence">
            <field name="name">descarga cfdi</field>
            <field name="code">registro_descarga</field>
            <field name="prefix">DES--</field>
            <field name="padding">3</field>
            <field name="company_id" eval="False"/>
        </record>

        

    </data>
</odoo>