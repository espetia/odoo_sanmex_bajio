<odoo>
    
  
        <record id="payment_fit_form" model="ir.ui.view">
            <field name="name">payment.fit.form</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="arch" type="xml">
                <field name="journal_id" position="after">
                    <field name="partner_parent_id" invisible="1"/>
                    <field name="cmpl_type" attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                    <field name="other_payment" 
                           attrs="{'readonly' : [('cmpl_type', '!=', 'payment')], 
                                   'required' : [('cmpl_type','=', 'payment')],
                                   'invisible': [('cmpl_type','!=', 'payment')],}"/>
                    <field name="partner_acc_id" widget="selection"
                           domain="['|',('partner_id', '=', partner_id),('partner_id', '=', partner_parent_id)]" 
                           attrs="{'required' : [('cmpl_type', '=', 'transfer')]}"/> 
                </field>
            </field>
        </record>

        <record id="payment_fit_invoice_form" model="ir.ui.view">
            <field name="name">payment.fit.invoice.form</field>
            <field name="model">account.payment.register</field>
            <field name="inherit_id" ref="account.view_account_payment_register_form"/>
            <field name="arch" type="xml">
                <field name="journal_id" position="after">
                    <field name="partner_id" invisible="1"/>
                    <field name="partner_parent_id" invisible="1"/>
                    <field name="cmpl_type" />
                    <field name="other_payment" 
                           attrs="{'readonly' : [('cmpl_type', '!=', 'payment')], 
                                   'required' : [('cmpl_type','=', 'payment')],
                                   'invisible': [('cmpl_type','!=', 'payment')],}"/>                    
                    <field name="partner_acc_id" widget="selection"
                           domain="['|',('partner_id', '=', partner_id),('partner_id', '=', partner_parent_id)]" 
                            attrs="{'readonly' : [('cmpl_type', 'not in', ['transfer', 'check'])], 'required' : [('cmpl_type', '=', 'transfer')]}"/>
                </field>
            </field>
        </record>
        
        <!-- Boton "Register Payment" en el formulario de la Factura -->
        <record id="payment_fit_invoice_form_button_pay" model="ir.ui.view">
            <field name="name">payment.fit.invoice.form</field>
            <field name="model">account.payment</field>
            <field name="inherit_id" ref="account.view_account_payment_form"/>
            <field name="arch" type="xml">
                <field name="journal_id" position="after">
                    <field name="partner_parent_id" invisible="1"/>
                    <field name="cmpl_type" />
                    <field name="other_payment" 
                           attrs="{'readonly' : [('cmpl_type', '!=', 'payment')], 
                                   'required' : [('cmpl_type','=', 'payment')],
                                   'invisible': [('cmpl_type','!=', 'payment')],}"/>                                        
                    <field name="partner_acc_id" widget="selection"
                           domain="['|',('partner_id', '=', partner_id),('partner_id', '=', partner_parent_id)]" 
                           attrs="{'readonly' : [('cmpl_type', 'not in', ['transfer', 'check'])], 'required' : [('cmpl_type', '=', 'transfer')]}"/>
                </field>
            </field>
        </record>
        
 
    
    
</odoo>