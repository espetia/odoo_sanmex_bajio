                        <field name="name"/>
                        <field name="fecha_creacion"/>
                        <field name="fecha_envio"/>
                        <field name="periodo_declaracion"/>
                        <field name="año_fiscal"/>
                        <field name="archivo_generado"/>
                        <field name="user_id"/>
                        <button name="presentar_declaracion" type="object" string="Presentar Declaración" class="oe_highlight"/>  
                    </group>
                     <notebook>
                            <page string="Declaraciones Presentadas">
                                <field name="presentadas_ids" readonly="0">
                                    <tree>
                                        <field name="name"/>
