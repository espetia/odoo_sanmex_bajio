                                        <field name="tipo_declaracion"/>
                                        <field name="fecha_recepcion"/> 
                                        <field name="folio_recepcion"/> 
                                        <field name="archivo_adj"/>                  
                                                                            
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                  </sheet>                      
                </form>
