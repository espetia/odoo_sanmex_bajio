                  <field name="archivo_generado"/>
                  <field name="user_id"/>
                  <field name="state"/>
                    
        </tree>
        </field>
      </record>
        <record id="action_sat_declaraciones" model="ir.actions.act_window">
            <field name="name">Declaraciones de Contabilidad Eléctronica</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">declaraciones.sat</field>
