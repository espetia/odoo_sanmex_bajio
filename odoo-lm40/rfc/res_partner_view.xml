<?xml version="1.0" encoding="utf-8"?>
<odoo>




           <record model="ir.ui.view" id="form_res_partner_rfc_fields_3_3">
            <field name="name">res.partner.cfdi.33</field>
            <field name="model">res.partner</field>
            <field name="type">form</field>
            <field name="priority">50</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <field name="vat" position="after" >
                    <field name="country_code_rel" invisible="1"/>
                    <field name="rfc" attrs="{'required':[('country_code_rel','=','MX')], 'invisible':[('country_code_rel','!=','MX')]}"/>
                </field>
                <xpath expr="//field[@name='vat']" position='attributes'>
                <attribute name="invisible">True</attribute>        
                </xpath>

             </field>
                     </record>


</odoo>

