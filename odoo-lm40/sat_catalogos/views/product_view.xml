<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- CATEGORIAS -->
        <record model="ir.ui.view" id="form_product_category_fields_3_3_einvoice_inhrt">
            <field name="name">product.category.cfdi.33</field>
            <field name="model">product.category</field>
            <field name="inherit_id" ref="stock_account.view_category_property_form"/>
            <field name="arch" type="xml">
                 
                <group name="account_property"  position="after">
                    <group name="product_sat" string="Atributos CFDI 3.3" groups="account.group_account_manager">
                        <group>
                            <field name="sat_product_id" options="{'no_create_edit': True,'no_create': True}" />
                        </group>
                        <group>
                           
                        </group>
                    </group>
                </group>
            </field>
        </record>

        <record id="counted_view_category_property_form" model="ir.ui.view">
            <field name="name">counted.product.category.property.form</field>
            <field name="model">product.category</field>
            <field name="inherit_id" ref="account.view_category_property_form"/>
            <field name="priority">50</field>
            <field name="arch" type="xml">
                <field name="property_account_expense_categ_id" position="before">
                        <field name="account_income"  />
                </field>
            </field>
        </record>

        <record model="ir.ui.view" id="tree_product_category_fields_3_3_einvoice_inhrt">
            <field name="name">product.category.cfdi.33</field>
            <field name="model">product.category</field>
            <field name="inherit_id" ref="product.product_category_list_view"/>
            <field name="arch" type="xml">
                <field name="display_name" position="after">
                    <field name="sat_product_id" />
               </field>
            </field>
        </record>
		
<!-- HERENCIA A PRODUCT TEMPLATE -->
        <record model="ir.ui.view" id="form_product_template_fields_3_3_einvoice_inhrt">
            <field name="name">product.template.cfdi.33</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="account.product_template_form_view"/>
            <field name="arch" type="xml">

                <field name="property_account_income_id" position="after">
                        <field name="account_income"  />
                </field>

                <group name="properties" position="before">
                    <group name="product_sat" string="Atributos CFDI 3.3" groups="account.group_account_manager">
                        <group>
                            <field name="sat_product_id" options="{'no_create_edit': True,'no_create': True}" required="1"/>
                        </group>
                        <group>
                            <field name="no_identity_type" required="1"/>
                            <field name="no_identity_other" attrs="{'invisible':[('no_identity_type','!=','manual')],'required':[('no_identity_type','=','manual')]}"/>
                        </group>
                        <separator string="Configuracion Contable" />
                    </group>
                </group>
            </field>
        </record>

        <record model="ir.ui.view" id="tree_product_template_fields_3_3_einvoice_inhrt">
            <field name="name">product.template.cfdi.33</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_tree_view"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="sat_product_id" />
               </field>
            </field>
        </record>

        <record model="ir.ui.view" id="tree_product_product_fields_3_3_einvoice_inhrt">
            <field name="name">product.product.cfdi.33</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_product_tree_view"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="sat_product_id" />
               </field>
            </field>
        </record>

