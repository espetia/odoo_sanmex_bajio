        <record model="ir.ui.view" id="form_product_UOM_fields_3_3_einvoice_inhrt">
            <field name="name">product.uom.cfdi.33</field>
            <field name="model">uom.category</field>
            <field name="inherit_id" ref="uom.product_uom_categ_form_view"/>
            <field name="arch" type="xml">
               
                 <xpath expr="//tree/field[@name='active']" position='replace'>
                   <field name="sat_uom_id" required="1" options="{'no_create_edit': True,'no_create': True}"/>      
                 </xpath>
                    <xpath expr="//tree/field[@name='rounding']" position='after'>
                    <field name="active"/>      
                 </xpath>
             
            </field>
        </record>
<!-- IMPUESTOS -->

        <record model="ir.ui.view" id="tree_account_tax_fields_3_3_einvoice_inhrt">
            <field name="name">account.tax.cfdi.33</field>
            <field name="model">account.tax</field>
            <field name="inherit_id" ref="account.view_tax_tree"/>
            <field name="arch" type="xml">
                <field name="type_tax_use" position="after">
                    <field name="sat_code_tax"/>
                    <field name="sat_tipo_factor_id" />                    
                    <field name="sat_tasa_cuota"/>
               </field>
            </field>
        </record>


        <record model="ir.ui.view" id="form_account_tax_fields_3_3_einvoice_inhrt">
            <field name="name">account.tax.cfdi.33</field>
            <field name="model">account.tax</field>
            <field name="inherit_id" ref="account.view_tax_form"/>
            <field name="arch" type="xml">
                <field name="children_tax_ids" position="before">
                    <group string="CFDI 3.3">
                        <group>
                            <field name="sat_tasa_cuota" required="1" options="{'no_create': True, 'no_open': True}"/>
                             <field name="sat_code_tax"  required="1" options="{'no_create': True, 'no_open': True}"/>                           
                            
                        </group>
                        <group>
                           <field name="sat_tipo_factor_id" required="1" options="{'no_create': True, 'no_open': True}"/>
                           <field name="estimulo_frontera"/>
                        </group>
                    </group>
               </field>
              
            </field>
        </record>
 
</odoo>
