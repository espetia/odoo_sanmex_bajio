       <record id="tipo_documento_list" model="ir.ui.view">
            <field name="name">tipo.documento.tree</field>
            <field name="model">tipo.documento</field>
            <field name="arch" type="xml">
                <tree string="Tipo de Documento">
                    <field name="code"/>
                    <field name="name"/>
                    <field name="tipo"/>
                </tree>
            </field>
        </record>

        <record id="tipo_documento_form" model="ir.ui.view">
            <field name="name">tipo.documento.form</field>
            <field name="model">tipo.documento</field>
            <field name="arch" type="xml">
                <form string="Tipos de Documento">
                    <sheet>                       

                        
                        <group >
                            <field name="code" />
                            <field name="name" />
                            <field name="forma_pago_id" />
                            <field name="pay_term_id" />
                            <field name="uso_cfdi_id" />
                            <field name="tipo"/>

                        </group>
                        
                    </sheet>
                    
                </form>
            </field>
        </record>


        

    <record id="action_tipo_documento" model="ir.actions.act_window">
            <field name="name">Tipos de Documentos</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">tipo.documento</field>
            <!--<field name="view_type">form</field>-->
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="tipo_documento_list"/>
        </record>

<menuitem action="action_tipo_documento"
                  id="action_tipo_documento_menu" sequence="1"
                  parent="account.menu_finance_configuration"/>

    <record id="view_account_invoice_filter_inherit_invoices_anticipos" model="ir.ui.view">
            <field name="name">account.invoice.select.inticipos</field>
            <field name="model">account.move</field>
            <field name="mode">primary</field>
            <field name="inherit_id" ref="account.view_account_invoice_filter"/>
            <field name="arch" type="xml">
                <data/>
            </field>
        </record>

        <record id="action_invoice_anticipos_tree1" model="ir.actions.act_window">
            <field name="name">Facturas de Anticipos</field>
            <field name="res_model">account.move</field>
            <!--<field name="view_type">form</field>-->
            <field name="view_mode">tree,kanban,form,pivot,graph</field>
            <field eval="False" name="view_id"/>
            <field name="domain">[('move_type','=','out_invoice'), ('deposit_invoice','=',True)]</field>
            <field name="context">{'move_type':'out_invoice', 'journal_type': 'sale'}</field>
            <field name="search_view_id" ref="account.view_account_invoice_filter"/>
            <field name="help" type="html">
              <p class="oe_view_nocontent_create">
                Click to create .
              </p>
            </field>
        </record>
        
        <record id="action_invoice_anticipos_tree" model="ir.actions.act_window.view">
            <field eval="1" name="sequence"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="account.view_invoice_tree"/>
            <field name="act_window_id" ref="action_invoice_anticipos_tree1"/>
        </record>

        <record id="action_invoice_anticipos_form" model="ir.actions.act_window.view">
            <field eval="2" name="sequence"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="account.view_move_form"/>
            <field name="act_window_id" ref="action_invoice_anticipos_tree1"/>
        </record>

        <menuitem action="action_invoice_anticipos_tree1"
                  id="menu_action_invoice_anticipos_tree1"
                  parent="account.menu_finance_receivables"
                  sequence="1"/>



        <record id="invoice_tree_currency_supplier" model="ir.ui.view">
            <field name="name">account.invoice.tree</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_invoice_tree"/>
            <field name="arch" type="xml">
                <field name="currency_id" position="replace">
                    <field name="currency_id" />
                </field>
                <field name="amount_total_signed" position="replace">
                    <field name="amount_total_signed" sum="x"/>
                </field>
                <field name="amount_residual_signed" position="replace">
                    <field name="amount_residual_signed" string="To Pay" sum="y"/>
                </field>
            </field>
        </record>
        
    

</odoo>
