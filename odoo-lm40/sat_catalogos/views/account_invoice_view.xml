<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <record id="view_invoice_tax_tree" model="ir.ui.view">
            <field name="name">account.invoice.tax.tree</field>
            <field name="model">account.invoice.tax</field>
            <field name="arch" type="xml">
                <tree string="Manual Invoice Taxes">
                    <field name="sequence"/>
                    <field name="manual"/>
                    <field name="name"/>
                    <field name="account_id" groups="account.group_account_user"/>
                    <field name="base"/>
                    <field name="amount_total"/>
                    <field name="currency_id" invisible="1"/>
                </tree>
            </field>
        </record>

        <record id="view_invoice_tax_form" model="ir.ui.view">
            <field name="name">account.invoice.tax.form</field>
            <field name="model">account.invoice.tax</field>
            <field name="arch" type="xml">
                <form string="Manual Invoice Taxes">
                    <group col="4">
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="account_id" groups="account.group_account_user"/>
                        <field name="account_analytic_id" domain="[('company_id', '=', parent.company_id)]" groups="analytic.group_analytic_accounting"/>
                        <field name="manual"/>
                        <field name="amount_total"/>
                        <field name="base"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </form>
            </field>
        </record>

     <record id="account_invoice_form_inherit_cfdi_33_search" model="ir.ui.view">
            <field name="name">account.invoice.cfdi.33.search</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_invoice_filter"/>
            <field name="arch" type="xml">
                <filter name="late" position="after">
                    <filter name="factura_relacion" string="Factura con Relacion" domain="[('type_rel_id','!=',False)]" invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund','out_receipt')"/>                    
                    <filter name="factura_timbrada" string="Facturas Timbrada" domain="[('state_sat','=','validate')]" invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund','out_receipt')"/>
                    <filter name="factura_notimbre" string="Factura No Timbrada" domain="[('state_sat','=','no_cfdi')]" invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund','out_receipt')"/>                    
                </filter>     
                   <filter name="salesperson" position="after">
                    <filter name="currency_id" string="Moneda" context="{'group_by':'currency_id'}"/>
                </filter> 

                
            </field>
        </record>

     <record model="ir.ui.view" id="account_invoice_form_inherit_cfdi_33_tree">
            <field name="name">account.invoice.cfdi.33.tree</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_invoice_tree"/>
            <field name="arch" type="xml">
                <field name="state" position="before">
                    <field name="deposit_invoice" invisible="1"/>
                    <field name="tipo_documento_id_nc" attrs="{'invisible':[('move_type','=','out_invoice')]}" domain="[('tipo','=','tipo_nc')]"/>
                    <field name="tipo_documento_id" attrs="{'invisible':[('move_type','=','out_refund')]}" domain="[('tipo','=','tipo_fac')]"/>
                    <field name="deposit_invoice_rel_id" invisible="1"/>
                    <field name="type_rel_id" invisible="1"/>
                    <field name="deposit_invoice_used" invisible="1"/>
                </field>
                <field name="state" position="after">
                    <field name="state_sat" string="Estado Sat" invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund','out_receipt')"/>
                </field>
                <field name="name" position="replace">
                    <field name="name" invisible="1"/>
                    <field name="name" string="Folio"/>
                </field>
                <field name="currency_id" position="replace">
                    <field name="currency_id" />
                </field>
                <field name="amount_total_signed" position="replace">
                    <field name="amount_total_signed" string="Total" sum="x"/>
                </field>
                <field name="amount_residual_signed" position="replace">
                    <field name="amount_residual_signed" string="Saldo" sum="y"/>
                </field>

            </field>
        </record>

     <record model="ir.ui.view" id="account_invoice_form_inherit_cfdi_33">
            <field name="name">account.invoice.cfdi.33</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                
                <header>
                        <button name="Timbrar_factura" type="object" string="TIMBRAR FACTURA" class="oe_highlight" groups="account.group_account_invoice" attrs="{'invisible':['|','|',('state', 'not in', ('posted')), ('payment_state', 'in', ('paid')), ('state_sat', 'in', ('validate'))]}" invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund','out_receipt')"/>
                        <button name="cancelar_timbre" type="object" attrs="{'invisible':['|','|',('state_sat', 'in', ('no_cfdi')), ('UUID','=',False),('payment_state', 'in', ('paid'))]}"  invisible="context.get('default_move_type') not in ('out_invoice', 'out_refund','out_receipt')" string="ENVIAR SOLICITUD DE CANCELACIÓN" class="oe_highlight" groups="account.group_account_invoice"/>                 
                </header>
                <field name="currency_id" position="after">
                    <field name="cancel_appply" invisible="1"/>
                </field>
                <field name="partner_id" position="after">
                    <field name="deposit_invoice" invisible="1"/>
                     <field name="tipo_documento_id_nc" attrs="{'invisible':[('move_type','!=','out_refund')], 'required': [('move_type','=','out_refund')]}" options="{'no_open': True,'no_create': True}" domain="[('tipo','=','tipo_nc')]"/>
                    <field name="tipo_documento_id" attrs="{'invisible':[('move_type','!=','out_invoice')], 'required': [('move_type','=','out_invoice')]}" options="{'no_open': True,'no_create': True}" domain="[('tipo','=','tipo_fac')]"/>
                    <field name="is_global" invisible="1" />
                    <field name="periodicidad" options="{'no_open': True,'no_create': True}" attrs="{'required' : [('is_global','=', True)],'invisible': [('is_global','=', False)]}"/>
                     <field name="meses_id" options="{'no_open': True,'no_create': True}" attrs="{'required' : [('is_global','=', True)],'invisible': [('is_global','=', False)]}"/>
                      <field name="year_report" attrs="{'required' : [('is_global','=', True)],'invisible': [('is_global','=', False)]}"/>
                      <field name="exportacion_id" options="{'no_open': True,'no_create': True}" attrs="{'required' : [('move_type','in', ('out_invoice', 'out_refund'))],'invisible': [('move_type','in', ('in_invoice', 'in_refund'))]}"/>
                    <field name="amount_deposit" attrs="{'invisible':[('deposit_invoice','!=',True)]}"/>
                </field>
                 <xpath expr="//field[@name='ref']" position="after">
                       <field name="invoice_payment_term_id" attrs="{'invisible': [('move_type', 'not in', ('out_invoice', 'out_refund', 'in_invoice', 'in_refund'))]}"/>
                   </xpath>
                   <xpath expr="//field[@name='invoice_date_due']" position="replace">
                       <field name="invoice_date_due" attrs="{'invisible': [('move_type', 'not in', ('out_invoice', 'out_refund', 'in_invoice', 'in_refund'))]}"/>
                   </xpath>

                <field name="ref" position="after">
                    <field name="MetodoPago" attrs="{'readonly':[('deposit_invoice','=',True)], 'required': [('move_type','=','out_invoice')], 'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}" options="{'no_create_edit': True,'no_create': True}"/>
                    <field name="UsoCFDI" attrs="{'readonly':[('deposit_invoice','=',True)], 'required': [('move_type','=','out_invoice')], 'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}" options="{'no_create_edit': True,'no_create': True}"/>
                    
                </field>
                
                    <xpath expr="//group[@id='other_tab_group']" position="after">
                   <group string="CFDI Relacionados" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}">              

                            <field name="type_rel_id" attrs="{'readonly':[('state','!=','draft')], 'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}" options="{'no_create_edit': True,'no_create': True}"/>
                            <field name="deposit_invoice_used" readonly="1" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>                      
                        
                            <field name="deposit_invoice" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>

                            <field name="deposit_invoice_rel_id" attrs="{'invisible':[('deposit_invoice_used','=',False)]}" readonly="1"/>

                    </group>
                    
                    
                   <field name="type_rel_cfdi_ids" attrs="{'readonly':[('state','!=','draft')], 'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}">
                        <tree string="CFDI Relacionados" editable="top">
                            <field name="invoice_id" options="{'no_create_edit': True,'no_create': True}" 
                                   />
                            <field name="onchange_domain" invisible="1" />
                        </tree>
                    </field>
                    <separator string="Impuestos" />
                    <field name="tax_line_ids">
                                <tree editable="bottom" string="Taxes" create="0">
                                    <field name="name"/>
                                    
                                    <field name="tax_id" invisible="1"/>
                                    <field name="account_analytic_id" invisible="1"/>
                                    <field name="sequence" invisible="1"/>
                                    <field name="manual" invisible="1"/>
                                    <field name="account_id" groups="account.group_account_user"/>
                                    <field name="amount" invisible="1"/>
                                    <field name="amount_rounding" invisible="1"/>
                                    <field name="amount_total"/>
                                    <field name="currency_id" invisible="1" force_save="1"/>
                                </tree>
                            </field>
                </xpath>
                    
                
                

                <field name="invoice_date" position="after">
                    <field name="invoice_datetime" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>                    
                    <field name="state_sat" attrs="{'invisible':['|', ('state','!=','posted'),('state','!=','paid'),('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>
                    
                </field>
                <field name="team_id" position="after">       
                    <field name="FormaPago" colspan="2" widget="many2many_tags" attrs="{'required': [('move_type','=','out_invoice')], 'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>
                    <field name="acc_payment" colspan="2" domain = "[('partner_id', '=', partner_id)]" context="{'default_partner_id': partner_id }" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>
                    <field name="direccion_compañia_id" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>
                    <field name="compañia_emisora_id" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>   
                </field>
                <notebook position="inside">
                    <page string="CFDI Info" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}">
                        <group colspan="4" col="3" >
                            <separator string="Informacion de Timbrado" colspan="2" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>
                            <field name="pac_timbre" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>
                            <field name="TipoDeComprobante" readonly="1" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>
                            <field name="UUID" readonly="1" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>                            
                            <field name="FechaTimbrado" readonly="1" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>
                            <field name="Sello" readonly="1" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>
                            <field name="no_certificado" readonly="1" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>                       
                            <field name="cfdi_cadena_original" readonly="1" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>                            
                            <field name="cfdi_cbb" widget="image" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}" options='{"size": [90, 90]}'/>
                            <separator string="Estado Timbrado" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}" colspan="2" readonly="1"/>                            
                            <field name="timbre" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>
                            <separator string="Información de Cancelación" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}" colspan="2" readonly="1"/>
                            <field name="cancel_solicitud" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>
                            <field name="cfdi_fecha_cancelacion" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}" readonly="1"/>
                            <field name="status_cancel" readonly="1" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>
                
                        </group>
                    </page>
                </notebook>
                 <xpath expr="//tree/field[@name='name']" position='after'>
                     <field name="no_ticket"/>        
                 </xpath>
                
                  <xpath expr="//tree/field[@name='price_unit']" position='after'>
                     <field name="objimp_id" options="{'no_open': True,'no_create': True}"/>        
                 </xpath>
                  <notebook position="inside">
                    <page string="Detalle de Ventas" attrs="{'invisible':[('is_global','=', False)]}">
                        <field name="sale_dateil_ids"> 
                        <tree editable="bottom" string="Detalle de Ventas">
                           
                               
                                <field name="concep_id"/>
                                <field name="order_id"/>
                                <field name="quantity"/>                    
                                <field name="precio_unit" />
                                <field name="discount"/>                       
                                <field name="taxes_id" widget="many2many_tags" domain="[('type_tax_use', '=?', parent.invoice_filter_type_domain)]" context="{'append_type_to_tax_name': not parent.invoice_filter_type_domain}" options="{'no_create': True}" force_save="1"/>                            
                                <field name="precio_subtotal"/>                                                       
                                <field name="price_tax"/>                            
                                <field name="precio_total"/>           
                            
                        </tree>
                        </field>
                    </page>
                </notebook>         
                
                
                <field name="team_id" position="replace" attrs="{'invisible':[('move_type','not in',('out_invoice', 'out_refund','out_receipt'))]}"/>
                
                   <field name="invoice_payment_term_id" position="attributes">
                    <attribute name="attrs">{'readonly':[('deposit_invoice','=',True)]}
                    </attribute>
                </field>
                <field name="invoice_line_ids" position="attributes">
                    <attribute name="attrs">{'readonly':[('deposit_invoice','=',True)]}
                    </attribute>
                </field>            
                
                
            </field>
            </record>



     <record model="ir.ui.view" id="payment_term_inherit_sat">
            <field name="name">account.payment.term.cfdi.33</field>
            <field name="model">account.payment.term</field>
            <field name="inherit_id" ref="account.view_payment_term_form"/>
            <field name="arch" type="xml">
                
                <field name="company_id" position="before">
                    <field name="metodo_pago_id" placeholder="Metodo Pago SAT" options="{'no_create_edit': True,'no_create': True}"/>
                </field>
                </field>
            </record>




