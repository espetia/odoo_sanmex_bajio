<?xml version="1.0" encoding="utf-8"?>
<odoo>
           <menuitem id="menu_cfdi" name="Control CFDI" parent="account.menu_finance" sequence="2"/>
    
<!-- CDFI -->

        <record id="cfdi_xml_list" model="ir.ui.view">
            <field name="name">cfdi.xml.tree</field>
            <field name="model">xmlcfdi</field>
            <field name="arch" type="xml">
                 <tree string="CFDI Timbrados" create="0" delete="0">
                    <field name="name"/>
                    <field name="cfdi_folio"/>
                    <field name="currency_id"/>
                    <field name="fecha_timbrado"/>
                    <field name="type_document"/>
                    <field name="pac_timbrado"/>
                    <field name="codigo_status"/>
                    <field name="status_cfdi"/>
                    <field name="Es_cancelable"/>
                    <field name="status_cancelacion"/>
                    <button name="consulta_estatus_cfdi" type="object" string="Consulta" class="oe_highlight"/>
                </tree>
            </field>
        </record>

        <record id="cfdi_xml_form" model="ir.ui.view">
            <field name="name">cfdi.xml.form</field>
            <field name="model">xmlcfdi</field>
            <field name="arch" type="xml">
                <form string="CFDI Timbrados" create="0" delete="0">
                    <header>
                  <button name="consulta_estatus_cfdi" type="object" string="Consulta" class="oe_highlight"/>
                
                </header>
                    <sheet>            
                        <group  string="Información de CFDI Timbrado">
                            <field name="name"/>
                            <field name="type_document"/>
                            <field name="cfdi_folio"/>
                            <field name="fecha_timbrado"/>                            
                            <field name="pac_timbrado"/>
                            <field name="cfdi_num_certificado"/>
                            <field name="cfdi_sello"/>                  
                            <field name="rfc_emisor"/>  
                            <field name="rfc_receptor"/>
                            <field name="total_docto"/>
                            <field name="currency_id"/>                                                   
                        </group>
                        <group string="Información Certificado SAT">
                           <field name="sello"/>
                            <field name="certificado"/>
                            <field name="cfdi_cadena_original"/> 
                            <field name="codigo_bm" widget="image" options='{"size": [90, 90]}'/>                           
                            <!--<field name="num_certificado"/>-->                            
                        </group>
                        <group string="Respuesta SAT">
                            <field name="codigo_status"/>
                            <field name="status_cfdi"/>
                            <field name="Es_cancelable"/>
                            <field name="status_cancelacion"/>
                        </group>
                        <!--<div aling="center">
                          <button type="object" name="consulta_estatus_cfdi" string="Consulta" class="oe_highlight"/>
                          
                        </div>  -->                   
                    </sheet>                    
                </form>
            </field>
        </record>


        <record id="cfdi_xml_search" model="ir.ui.view">
            <field name="name">cfdi.xml.serch</field>
            <field name="model">xmlcfdi</field>
            <field name="arch" type="xml">
                <search string="Busqueda cfdi">
                     <field name="name" filter_domain="['|', ('cfdi_folio','ilike',self),('name','ilike',self)]" string="Facturas ..."/>
                    <field name="cfdi_folio"/>
                    <field name="name"/>
                    <field name="pac_timbrado"/>
                    
                </search>
            </field>
        </record>

    <record id="action_cfdi_xml" model="ir.actions.act_window">
            <field name="name">CFDI's Timbrados</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">xmlcfdi</field>
            <!--<field name="view_type">form</field>-->
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="cfdi_xml_list"/>
        </record>

<menuitem action="action_cfdi_xml"
                  id="action_cfdi_menu" sequence="0"
                  parent="menu_cfdi" />

  <!--Cancelacion de CFDI-->                
            <record id="cfdi_cancelar_list" model="ir.ui.view">
            <field name="name">cfdi.cancelar.tree</field>
            <field name="model">cancelaciones</field>
            <field name="arch" type="xml">
                 <tree string="CFDI A cancelare" create="0" delete="0">
                    <field name="name"/>
                    <field name="factura"/>
                    <field name="cfdi_folio"/>
                    <field name="fecha_timbrado"/>
                    <field name="type_document"/>
                    <field name="pac_timbrado"/>
                    <field name="codigo_status"/>
                    <field name="status_cfdi"/>
                    <field name="Es_cancelable"/>
                    <field name="status_cancelacion"/>
                    <field name="state"/>
                    <button name="consulta_estatus" type="object" string="Consulta" class="oe_highlight"/>
                </tree>
            </field>
        </record>

        <record id="cfdi_cancelar_form" model="ir.ui.view">
            <field name="name">cfdi.xml.form</field>
            <field name="model">cancelaciones</field>
            <field name="arch" type="xml">
               
                <form string="CFDI a Cancelar" create="0" delete="0">
                     <header>
                  <button name="consulta_estatus" type="object" string="Consulta" class="oe_highlight"/>
                
                </header>
                    <sheet>            
                        <group  string="Información de CFDI">
                            <field name="name"/>
                            <field name="factura"/>
                            <field name="type_document"/>
                            <field name="cfdi_folio"/>
                            <field name="fecha_timbrado"/>                            
                            <field name="pac_timbrado"/>
                            <field name="cfdi_num_certificado"/>
                            <field name="cfdi_sello"/>                  
                            <field name="rfc_emisor"/>  
                            <field name="rfc_receptor"/>
                            <field name="total_docto"/>                                                   
                        </group>
                        <group string="Información Certificado SAT">
                           <field name="sello"/>
                            <field name="certificado"/>
                            <field name="cfdi_cadena_original"/> 
                            <field name="codigo_bm"/>                           
                                                      
                        </group>
                        
                        <notebook>
                    <page string="Proceso de Cancelación">
                        <group colspan="2" col="2" > 
                       <group string="Solicitud">                          
                            <field name="fecha_cancelacion" />
                            <field name="rfemisior"/>
                            <field name="folio_cancelacion"/>  
                            <field name="codigo_solicitud"/>                
                        </group>
                        <group string="Repuesta">
                            <field name="codigo_status"/>
                            <field name="status_cfdi"/>
                            <field name="Es_cancelable"/>
                            <field name="status_cancelacion"/>
                        </group>
                    </group>
                    </page>
                </notebook>
                    </sheet>
                    
                </form>
            </field>
        </record>


        <record id="cfdi_cancelar_search" model="ir.ui.view">
            <field name="name">cfdi.cancelar.serch</field>
            <field name="model">cancelaciones</field>
            <field name="arch" type="xml">
                <search string="Busqueda cfdi">
                     <field name="factura" filter_domain="['|', ('cfdi_folio','ilike',self),('factura','ilike',self)]" string="Facturas ..."/>
                    <field name="cfdi_folio"/>
                    <field name="factura"/>
                    <field name="pac_timbrado"/>
                    
                </search>
            </field>
        </record>

    <record id="action_cfdi_cancelar" model="ir.actions.act_window">
            <field name="name">Cancelaciones CFDI</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">cancelaciones</field>
           <!-- <field name="view_type">form</field>-->
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="cfdi_cancelar_list"/>
        </record>




<menuitem action="action_cfdi_cancelar"
                  id="action_cfdi_cancelar_menu" sequence="0"
                  parent="menu_cfdi" />


</odoo>