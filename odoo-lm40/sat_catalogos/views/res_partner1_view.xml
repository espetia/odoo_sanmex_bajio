<?xml version="1.0" encoding="utf-8"?>
<odoo>
    

                    

        <record model="ir.ui.view" id="res_partner_locality_sat_form">
            <field name="name">res.partner.tree.sat.code.locality</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <field name="vat" position="before">
                  <field name="tipo_contribuyente" widget="selection"/>
                   <field name="objimp_id" requiered="1" options="{'no_open': True,'no_create': True}"/>
                </field>
                <field name="state_id" position="attributes">
                    <attribute name="options">{'no_create_edit': True,'no_create': True}</attribute>
                </field>
                <field name="country_id" position="before">
                    <field name="sat_localidad_id" placeholder="Localidad" class="o_address_city oe_edit_only" options="{'no_create_edit': True,'no_create': True}" attrs="{'invisible':[('country_code_rel','!=','MX')]}"/>
                </field>
                <field name="street2" position="after">
                    <field name="sat_codigopostal_id" placeholder="Codigo Postal" class="o_address_zip" options="{'no_create_edit': True,'no_create': True}" attrs="{'invisible':[('country_code_rel','!=','MX')]}"/>
                    <field name="colonia_sat_id" placeholder="Colonia" class="oe_edit_only" attrs="{'invisible':[('country_code_rel','!=','MX')]}"/>
                </field>
                <field name="city" position="replace">
                    <field name="city" invisible="1" />
                    <field name="sat_municipio_id" placeholder="Municipio" class="oe_edit_only" options="{'no_create_edit': True,'no_create': True}" attrs="{'invisible':[('country_code_rel','!=','MX')]}"/>
                </field>
                <field name="zip" position="replace">
                    <field name="zip" attrs="{'invisible':[('country_code_rel','=','MX')]}" />
                </field>
                <field name="street" position="after">
                        <div attrs="{'invisible':[('country_code_rel','!=','MX')]}">
                            <field name="num_external" placeholder="No. External..." style="width: 45%;" 
                                   attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}"/>
                            -
                            <field name="num_internal" placeholder="No. Internal..." style="width: 45%;" 
                                   attrs="{'readonly': [('type', '=', 'contact'),('parent_id', '!=', False)]}"/>
                        </div>
                    </field>

                </field>
            </record>
            
        <record model="ir.ui.view" id="view_partner_form_inh_xml22">
            <field name="name">view.partner.form.inh.xml22</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="account.view_partner_property_form"/>
            <field name="arch" type="xml">
                <field name="bank_ids" position="after">
                    
                    <field name="regimen_fiscal_id" groups="account.group_account_manager" options="{'no_create_edit': True,'no_create': True}" />
                    <field name="pay_method_id" widget="selection" groups="account.group_account_manager"/>
                    
                </field>

            </field>
        </record>   
        
        
        
    
</odoo>
