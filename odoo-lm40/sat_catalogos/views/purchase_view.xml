<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

    
    <record model="ir.config_parameter" id="tolerance_range_between_invoice_record_and_cfdi_xml_file">     
      <field name="key">rango_entre_registro_factura_y_xmlcfdi</field> 
      <field name="value">1.0</field>
    </record>

    </data>
        <record model="ir.ui.view" id="view_res_company_inherit_bank_form">
            <field name="name">view.res.company.inherit.bank.form</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <field name="picking_type_id" position="after">
                    <field name="acc_payment" domain="[('partner_id', '=', partner_id)]"/>
                    <field name="pay_method_id" widget="selection" string="Forma de Pago"/>
                </field>
            </field>
        </record>
    <record id="invoice_fit_form" model="ir.ui.view">
            <field name="name">invoice.fit.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <!--<button name="action_invoice_draft" position="replace">
                    <button name="action_invoice_draft" type='object' string="Establecer a Borrador"/>
                </button>-->
                <field name="fiscal_position_id" position="after">
                    <field name="valida_nosat" invisible="context.get('default_move_type') not in ('in_invoice', 'in_refund','in_receipt')"/>
                    
                </field>
                <field name="ref" position="attributes">
                    <attribute name="attrs">{'readonly':[('deposit_invoice','=',True)], 'required': [('move_type','=','in_invoice')], 'invisible':[('move_type','=','out_invoice')]}</attribute>
                    
                </field>
                    <field name="ref" position="after">
                        <field name="uuid_factura" invisible="context.get('default_move_type') not in ('in_invoice', 'in_refund','in_receipt')"/>
                    </field>
            </field>
        </record>

       <record id="cfdi__supplier_list" model="ir.ui.view">
            <field name="name">cfdi.proveedores.tree</field>
            <field name="model">registro.invoice</field>
            <field name="arch" type="xml">
                 <tree string="Registro de Fcaturas de Proveedor" create="0" delete="0">
                    <field name="name" />
                    <field name="partner_id"/>
                    <field name="UUID" />
                    <field name="fecha_creacion"/>
                    <field name="currency_id" />
                    <field name="monto_total"/>
                    <field name="estado_factura"/>
                </tree>
            </field>
        </record>

        <record id="cfdi_supplier_form" model="ir.ui.view">
            <field name="name">cfdi.supplier.form</field>
            <field name="model">registro.invoice</field>
            <field name="arch" type="xml">
                <form string="Registro de CFDI Proveedores" create="0" delete="0">
                    <sheet>
                         <group>
                            <field name="name" />
                            <field name="partner_id"/>
                            <field name="UUID"/>
                            <field name="fecha_creacion" />
                            <field name="rfc_emisor"/>
                            <field name="rfc_receptor" />
                            <field name="estado_factura"/>
                            <field name="monto_total" />
                            <field name="currency_id"/>
                         </group>
                         
                    </sheet>                    
                </form>
            </field>
        </record>


        

    <record id="action_registro" model="ir.actions.act_window">
            <field name="name">Registro de CFDI Proveedores</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">registro.invoice</field>
            <!--<field name="view_type">form</field>-->
            <field name="view_mode">tree,form</field>
            <field name="view_id" ref="cfdi__supplier_list"/>
        </record>


<menuitem id="menu_registro_proveedor" name="CFDI Proveedores" parent="account.menu_finance_payables" sequence="2"/>

<menuitem action="action_registro"
                  id="action_registro_menu" sequence="0"
                  parent="menu_registro_proveedor" />


</odoo>
