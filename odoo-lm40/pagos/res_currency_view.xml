<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_currency_tree" model="ir.ui.view">
        <field name="name">res.currency.tree</field>
        <field name="model">res.currency</field>
        <field name="inherit_id" ref="base.view_currency_tree"/>
        <field name="arch" type="xml">
            <field name="rate" position="attributes">
                <attribute name="string">Tasa Convertida</attribute>
            </field>
            <field name="rate" position="after">
                <field name="rate_custom"  string="Tasa Normal"/>
            </field>
        </field>
    </record>

    <record id="view_currency_form" model="ir.ui.view">
        <field name="name">res.currency.form</field>
        <field name="model">res.currency</field>
        <field name="inherit_id" ref="base.view_currency_form"/>
        <field name="arch" type="xml">
            <field name="name" position="attributes">
                <attribute name="string">Moneda</attribute>
            </field>
            <field name="name" position="after">
                <field name="rate_custom"  string="Tasa Normal"/>
                <button name="update_tasa_custom" string="Actualizar Tasas Normal" type="object"  class="oe_link"/>
            </field>
             <xpath expr="//tree/field[@name='rate']" position='attributes'>
                <attribute name="invisible">1</attribute>
                <attribute name="string">Tasa Convertida</attribute>
        </xpath>
        <xpath expr="//tree/field[@name='rate']" position='after'>
            <field name="rate_custom" string="Tasa Normal"/>
          </xpath>  
        </field>
    </record>


</odoo>
