<?xml version="1.0" encoding="utf-8"?>
<odoo>
        
    <data noupdate="1">
        
        
    
        <record model="account.account.type" id="data_account_type_view">
          <field name="name">Vista</field>
          <field name="type">view</field>          
          <field name="internal_group">off_balance</field>
        </record>
        
         <record model="account.account.type" id="data_account_type_consolidation">
        <field name="name">Consolidación</field>
          <field name="type">consolidation</field>
         
         <field name="internal_group">off_balance</field>
        </record>
        
    </data>
    
            
        <record id="view_account_account_form_parent" model="ir.ui.view">
            <field name="name">Chart of Accounts Tree Structure</field>
            <field name="model">account.account</field>
            <field name="inherit_id" ref="account.view_account_form"/>
            <field name="arch" type="xml">
                <field name="name" position="after" >
                    <field name="parent_id" domain="[('id','!=',id),('internal_type','=','view')]"/>
                </field>
                <field name="user_type_id" position="after" >
                    <field name="child_consol_ids" widget="many2many_tags"
                           attrs="{'invisible':[('internal_type','not in',('consolidation'))]}" />
                </field>
                <field name="deprecated" position="before">
                    <field name="partner_breakdown"  attrs="{'invisible':[('internal_type','=','view')]}"/>
                    <field name="sign"/>
                    <field name="sing_1"/>
                </field>
                <field name="deprecated" position="after">                    
                    <h3 style="color: #7c7bad;text-decoration : underline">Contabilidad Electrónica</h3><br/>
                        <field name="in_debt"/>
                        <field name="in_cred"/>
                        <field name="xml_report"/>                        
                        <field name="sat_code_id" attrs="{'invisible' : [('xml_report', '=', False)], 'required' : [('xml_report', '=', True)]}"/>
                         <field name="first_period_id" attrs="{'invisible' : [('xml_report', '=', False)], 'required' : [('xml_report', '=', True)]}"/>
                    <h3 style="color: #7c7bad;text-decoration : underline">Datos de cuenta bancaria</h3><br/>
                        <field name="account_bank" attrs="{'invisible' : [('user_type_id', '!=', 3)]}"/>
                        <field name="bank_id" attrs="{'invisible' : [('user_type_id', '!=', 3)]}"/>
                        <field name="currency_id" attrs="{'invisible' : [('user_type_id', '!=', 3)]}"/>
                            
                        
                </field>
            </field>
        </record>

        
        <record id="account_conta_tree" model="ir.ui.view">
            <field name="name">account.conta.tree</field>
            <field name="model">account.account</field>
            <field name="inherit_id" ref="account.view_account_list"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="sat_code_id"/>
                </field>
            </field>
        </record>      
        
        
        
        
    <record id="view_move_form_line_ids_account_id_no_view_no_consol" model="ir.ui.view">
        <field name="name">account.move.line_ids.account_id</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='line_ids']/tree/field[@name='account_id']" position="replace">
                <field name="account_id" domain="[('company_id', '=', parent.company_id), ('internal_type','not in', ('deprecated', 'view','consolidation'))]"/>
            </xpath>
        </field>
    </record>        
        
    
</odoo>
