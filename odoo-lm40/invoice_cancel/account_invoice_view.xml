<odoo>
<data>
    
        <record id="wiz_view_invoice_cancel_argil" model="ir.ui.view">
            <field name="name">account.invoice.cancel_wizard</field>
            <field name="model">account_invoice.cancel_wizard</field>
            <field name="arch" type="xml">
                <form string="Cancelar Factura?">
                    <group col="4" colspan="4">
                        <field name="date" default_focus="1"/>
                        <field name="journal_id" />
                    </group>
                    <p class="oe_grey">
                        Si la Factura tiene una póliza contable entonces se creará 
                        una póliza de Cancelación, conciliando las partidas 
                        correspondientes para "matar" el saldo.
                    </p>
                    <footer>
                        <button string="Cancelar Factura" name="action_cancel" type="object" default_focus="1" class="btn-primary"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_invoice_cancel_wizard" model="ir.actions.act_window">
          <field name="name">Cancelar Factura</field>
          <field name="type">ir.actions.act_window</field>
          <field name="res_model">account_invoice.cancel_wizard</field>
         
          <field name="view_mode">form</field>
          <field name="target">new</field>
        </record>    
    
    
         <record id="view_invoice_cancel" model="ir.ui.view">
            <field name="name">account.invoice.form.invoice_cancel</field>
            <field name="model">account.move</field>
            <field name="type">form</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//button[@name='button_cancel']" position="after">
                    <button name="%(action_invoice_cancel_wizard)d" type='action'
                            states="draft,posted" string="Asiento de reversión" groups="account.group_account_invoice"/>
                </xpath>
                <!--<field name="move_id" position="replace">-->
                    <!--<field name="move_id" attrs="{'invisible':[('move_id','=',False)]}" />-->
                    <field name="invoice_incoterm_id" position="after">
                    <field name="original_move_id"/>
                    <field name="cancel_move_id" attrs="{'invisible':[('cancel_move_id','=',False)]}" />
                </field>
            </field>
        </record>
        
        

    
</data>
</odoo>
