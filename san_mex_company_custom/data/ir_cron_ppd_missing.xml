<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_ppd_missing_reminder" model="ir.cron">
            <field name="name">Purchase Order: Send PPD Missing Reminder</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_ppd_missing_reminder(start_date='2025-05-25')</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d 14:00:00')"/>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
