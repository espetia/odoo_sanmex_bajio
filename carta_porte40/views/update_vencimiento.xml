<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record forcecreate="True" id="ir_cron_seguros_timed_out_update" model="ir.cron">
        <field name="name">Seguros: timed out update</field>
        <field name="model_id" ref="model_cat_seguros"/>
        <field name="state">code</field>
        <field name="code">model.time_out_update(True)</field>
        <field eval="True" name="active"/>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="numbercall">-1</field>
        
        <field eval="False" name="doall"/>
    </record>

</odoo>
