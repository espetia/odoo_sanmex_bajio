<?xml version="1.0" encoding="utf-8"?>
 <odoo>

    

        <!-- Sequences for sale.order -->
        <record id="seq_ubicacion_origen" model="ir.sequence">
            <field name="name">Ubicacion Origen</field>
            <field name="code">origenes</field>
            <field name="prefix">OR/</field>
            <field name="padding">6</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_ubicacion_dest" model="ir.sequence">
            <field name="name">Ubicacion Destino</field>
            <field name="code">destinos</field>
            <field name="prefix">DE/</field>
            <field name="padding">6</field>
            <field name="company_id" eval="False"/>
        </record>

    <record model="ir.ui.view" id="res_partner_owner_form">
            <field name="name">res.partner.form.owner</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <field name="category_id" position="after">
                  <field name="is_owner"/>
                  <field name="tipofigura" attrs="{'invisible':[('is_owner', '=', False)], 'required':[('is_owner', '=', True)]}"/>
                  
                </field>
                

                </field>
            </record>


  <record id="view_carta_porte_picking_form" model="ir.ui.view">
        <field name="name">stock.picking.carta.porte</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
             <header>
                        <button name="timbra_traslado" type="object" string="Generar CFDI Traslado" class="oe_highlight" attrs="{'invisible':['|','|',('carta_porte', '!=', 'cartaporte'), ('state_sat', 'in', ('validate')), ('state', '!=', 'done')]}"/>
                                        
                </header>
            <field name="origin" position="after">
       <field name="carta_porte" attrs="{'invisible':[('picking_type_code', 'not in', ('outgoing', 'internal'))], 'readonly':[('state_sat', 'in', ('validate'))]}"/>
                  <field name="is_federal" attrs="{'invisible':[('carta_porte', '!=', 'cartaporte')], 'readonly':[('state_sat', 'in', ('validate'))]}"/>    
                </field>
            <xpath expr="//notebook" position="inside">
                  <page name="datos_cartaporte" string="Datos Carta Porte" attrs="{'invisible':[('carta_porte', '!=', 'cartaporte')]}">
                    <group cols="4">

                        <group string='Información General'>
                        
                        <field name="TranspInternac" attrs="{'required':[('carta_porte', '=', 'cartaporte')], 'readonly':[('state_sat', 'in', ('validate'))]}"/>
                         <field name="EntradaSalidaMerc" attrs="{'invisible':[('TranspInternac', '=', 'no')], 'required':[('TranspInternac', '=', 'si')], 'readonly':[('state_sat', 'in', ('validate'))]}"/>
                         <field name="PaisOrigenDestino" attrs="{'invisible':[('TranspInternac', '=', 'no')], 'required':[('TranspInternac', '=', 'si')], 'readonly':[('state_sat', 'in', ('validate'))]}"/>
                         <field name="ViaEntradaSalida" attrs="{'invisible':[('TranspInternac', '=', 'no')], 'required':[('TranspInternac', '=', 'si')], 'readonly':[('state_sat', 'in', ('validate'))]}"/>
                         <field name="fechaHorasalidallegada_origen" attrs="{'required': [('carta_porte', '=', 'cartaporte')], 'readonly':[('state_sat', 'in', ('validate'))]}"/>
                         <field name="fechaHorasalidallegada_destino" attrs="{'required': [('carta_porte', '=', 'cartaporte')], 'readonly':[('state_sat', 'in', ('validate'))]}"/>
                         <field name="CargoPorTasacion" attrs="{'readonly':[('state_sat', 'in', ('validate'))]}"/>
                         
                         <field name="distanciarecorrida" attrs="{'required':[('carta_porte', '=', 'cartaporte')], 'readonly':[('state_sat', 'in', ('validate'))]}"/>  
                         <field name="PesoBrutoTota" attrs="{'required': [('carta_porte', '=', 'cartaporte')], 'readonly':[('state_sat', 'in', ('validate'))]}"/> 
                         <field name="UnidadPeso" attrs="{'required': [('carta_porte', '=', 'cartaporte')], 'readonly':[('state_sat', 'in', ('validate'))]}"/>                      
                       </group>  
                        <group string='Ubicaciones'>
                             <field name="ubicaciones_ids" string="Ubicaciones" attrs="{'readonly':[('state_sat', 'in', ('validate'))]}">
                            <tree editable="bottom">
                                <field name="TipoUbicacion"/>
                                <field name="IDUbicacion" />                                
                                 <field name="partner_id_t"/>
                            </tree>
                        </field>                      
                   
                  </group>
                       <group string='Transporte'>                  
                        <field name="trasporte_vehiculo" attrs="{'required': [('carta_porte', '=', 'cartaporte')], 'readonly':[('state_sat', 'in', ('validate'))]}"/>
                        <field name="partner_owner" attrs="{'readonly':[('state_sat', 'in', ('validate'))]}"/>
                         <field name="remolques_ids" string="Remolques" attrs="{'readonly':[('state_sat', 'in', ('validate'))]}">
                            <tree editable="bottom">
                                <field name="remolque_id"/>
                               
                            </tree>
                             
                        </field>           
                       
                             <field name="figuratrasnporte_ids" string="Figura Transporte" attrs="{'readonly':[('state_sat', 'in', ('validate'))]}">
                                <tree editable="bottom">
                                    <field name="figuratrasnporte"/>
                                    <field name="numlicencia" /> 
                                    <field name="rfcfigura" /> 
                                    <field name="tipofigura" />                             
                                </tree>
                            </field>          
                        </group>
                         
                        <group string="Seguros">
                         <group>
                            <field name="tipo_seguro_civil" attrs="{'readonly':[('state_sat', 'in', ('validate'))]}"/>
                             <field name="asegurado_civil" attrs="{'invisible':[('tipo_seguro_civil', '=', False)], 'required': [('carta_porte', '=', 'cartaporte')]}"/>
                         </group>
                         <group>
                            <field name="tipo_seguro_amb" attrs="{'readonly':[('state_sat', 'in', ('validate'))]}"/> 
                            <field name="asegurado_amb" attrs="{'invisible':[('tipo_seguro_amb', '=', False)], 'required': [('tipo_seguro_amb', '=', True)]}"/> 
                             </group> 
                             <group>
                            <field name="tipo_seguro_carga" attrs="{'readonly':[('state_sat', 'in', ('validate'))]}"/>
                            <field name="asegurado_carga" attrs="{'invisible':[('tipo_seguro_carga', '=', False)], 'required': [('tipo_seguro_carga', '=', True)]}"/> 
                             </group>
                             <group>
                            <field name="tipo_seguro_vmercancia" attrs="{'readonly':[('state_sat', 'in', ('validate'))]}"/>   
                            <field name="asegurado_vmercancia" attrs="{'invisible':[('tipo_seguro_vmercancia', '=', False)], 'required': [('tipo_seguro_vmercancia', '=', True)]}"/>                                  
                          </group>
                  </group>
                  </group>
                  <group string='Mercancías'>                  
                        
                             <field name="mercancias_ids" string="Mercancías" attrs="{'readonly':[('state_sat', 'in', ('validate'))]}">
                                <tree editable="bottom">
                                    <field name="para_cartaporte"/>
                                    <field name="product_id"/>
                                    <field name="product_uom" /> 
                                    <field name="product_qty" /> 
                                    <field name="dimensiones" />   
                                    <field name="materialpeligroso"/>
                                    <field name="embalaje" attrs="{'invisible':[('materialpeligroso', '=', 'no')], 'required': [('materialpeligroso', '=', 'si')]}"/>
                                    <field name="CveMaterialPeligroso" attrs="{'invisible':[('materialpeligroso', '=', 'no')], 'required': [('materialpeligroso', '=', 'si')]}"/>                                   
                                    <field name="currency" /> 
                                    <field name="valorproducto" /> 
                                    <field name="peso" />           
                                </tree>
                            </field>          
                        </group>
                </page>        
                 <page string="CFDI Info" attrs="{'invisible':[('carta_porte', '!=', 'cartaporte')]}">
                        <group colspan="4" col="3" >
                            <separator string="Informacion de Timbrado" colspan="2" />
                            <field name="pac_timbre" />
                            <field name="TipoDeComprobante" readonly="1" />
                            <field name="state_sat"/>
                            <field name="UUID" readonly="1"/>                            
                            <field name="FechaTimbrado" readonly="1"/>
                            <field name="Sello" readonly="1" />
                            <field name="no_certificado" readonly="1" />                       
                            <field name="cfdi_cadena_original" readonly="1"/>                            
                            <field name="cfdi_cbb" widget="image" options='{"size": [90, 90]}'/>                    
                            
                
                        </group>
                    </page>
            </xpath>
        </field>
    </record>

      <record id='fleet_vehicle_cartaporte_view_form' model='ir.ui.view'>
        <field name="name">fleet.vehicle.cartaporte.form</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <field name="location" position="after">
                 
                     
                        <field name="vehiculo_is" />
                     <field name="categoiria_vehiculo" />
                     <field name="SubTipoRem" attrs="{'invisible':[('categoiria_vehiculo', '!=', 'remolque')], 'required': [('categoiria_vehiculo', '=', 'remolque')]}"/>

                     <field name="PermSCT" attrs="{'invisible':[('categoiria_vehiculo', '!=', 'vehiculo')], 'required': [('categoiria_vehiculo', '=', 'vehiculo')]}"/>
                     <field name="NumPermisoSCT" attrs="{'invisible':[('categoiria_vehiculo', '!=', 'vehiculo')], 'required': [('categoiria_vehiculo', '=', 'vehiculo')]}"/>
                     <field name="ConfigVehicular" attrs="{'invisible':[('categoiria_vehiculo', '!=', 'vehiculo')], 'required': [('categoiria_vehiculo', '=', 'vehiculo')]}"/>                  
            
                 <field name="remolques_ids" string="Remolques" attrs="{'invisible':[('categoiria_vehiculo', '!=', 'vehiculo')], 'required': [('categoiria_vehiculo', '=', 'vehiculo')]}">
                            <tree editable="bottom">
                                <field name="remolque_id"/>
                                <field name="SubTipoRem" /> 
                                <field name="license_plate" />                                                          
                            </tree>
                        </field>  
                        <field name="partner_owner" attrs="{'invisible':[('categoiria_vehiculo', '=', 'remolque')]}"/>
                         <field name="parte_transporte" attrs="{'invisible':[('categoiria_vehiculo', '=', 'remolque')], 'required':[('partner_owner','!=', False)]}"/>
                 </field>      
        </field>
    </record>

</odoo>